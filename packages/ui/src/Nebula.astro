---
/**
 * Nebula — fondo de "nebulosa pulsante": nubes de gas cósmico que respiran
 * (pulsan en tamaño y brillo) y derivan lentamente, con partículas brillantes
 * flotando dentro. Glow aditivo sobre fondo oscuro; orgánico y suave.
 * Canvas puro, fallback para reduced-motion, pausa al ocultar la pestaña y al
 * hacer scroll más allá del hero. Capa fija a viewport (z-index -1).
 * Singleton: usar una sola vez por página.
 *
 * Props:
 *   speed — multiplicador de velocidad de pulso/deriva (1 = por defecto).
 */
export interface Props {
  speed?: number;
}

const { speed = 1 } = Astro.props;
---

<div class="nebula-bg" aria-hidden="true" data-speed={speed}>
  <canvas id="nebula-canvas"></canvas>
</div>

<style>
  .nebula-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 120% 90% at 50% 40%, rgb(12 8 40 / 0.6), transparent 75%),
      #04030b;
  }

  #nebula-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  (() => {
    const root = document.querySelector('.nebula-bg') as HTMLElement | null;
    const canvas = document.getElementById('nebula-canvas') as HTMLCanvasElement | null;
    const ctx = canvas?.getContext('2d');
    if (!root || !canvas || !ctx) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const speedMult = Number(root.dataset.speed) || 1;

    interface Blob {
      ax: number; ay: number;       // ancla (fracción de W/H)
      rFrac: number;                // radio base como fracción de maxDim
      color: string;                // "r, g, b"
      alpha: number;
      driftX: number; driftY: number; // amplitud de deriva (px)
      ds: number; ps: number;       // velocidades de deriva / pulso
      phase: number; depth: number; // depth → parallax
    }
    interface Dust { x: number; y: number; vx: number; vy: number; r: number; a: number; tw: number; ph: number; }

    const BLOBS: Blob[] = [
      { ax: 0.28, ay: 0.34, rFrac: 0.42, color: '0, 110, 255',  alpha: 0.26, driftX: 60, driftY: 40, ds: 0.00010, ps: 0.00045, phase: 0.0, depth: 0.5 },
      { ax: 0.72, ay: 0.42, rFrac: 0.38, color: '0, 198, 231',  alpha: 0.22, driftX: 50, driftY: 55, ds: 0.00013, ps: 0.00038, phase: 1.6, depth: 0.8 },
      { ax: 0.52, ay: 0.58, rFrac: 0.46, color: '150, 70, 255', alpha: 0.24, driftX: 70, driftY: 45, ds: 0.00009, ps: 0.00052, phase: 3.0, depth: 0.35 },
      { ax: 0.40, ay: 0.66, rFrac: 0.30, color: '255, 60, 170', alpha: 0.18, driftX: 55, driftY: 50, ds: 0.00012, ps: 0.00060, phase: 4.4, depth: 1.0 },
      { ax: 0.82, ay: 0.74, rFrac: 0.34, color: '0, 220, 180',  alpha: 0.18, driftX: 45, driftY: 40, ds: 0.00011, ps: 0.00041, phase: 5.5, depth: 0.6 },
    ];

    let W = 0, H = 0, maxDim = 0;
    let dust: Dust[] = [];
    let running = true;
    let parX = 0, parY = 0, tgtX = 0, tgtY = 0;

    const rand = (a: number, b: number) => Math.random() * (b - a) + a;

    function buildDust() {
      const count = Math.min(Math.max(Math.round((W * H) / 11000), 60), 180);
      dust = [];
      for (let i = 0; i < count; i++) {
        dust.push({
          x: rand(0, W), y: rand(0, H),
          vx: rand(-0.12, 0.12), vy: rand(-0.12, 0.12),
          r: rand(0.4, 1.8), a: rand(0.3, 0.9),
          tw: rand(0.5, 1.8), ph: rand(0, Math.PI * 2),
        });
      }
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = window.innerWidth;
      H = window.innerHeight;
      maxDim = Math.max(W, H);
      canvas!.width = W * dpr;
      canvas!.height = H * dpr;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildDust();
    }

    function drawBlobs(t: number) {
      ctx!.globalCompositeOperation = 'lighter';
      for (const b of BLOBS) {
        const pulse = reduceMotion ? 1 : 1 + 0.14 * Math.sin(t * b.ps * speedMult + b.phase);
        const r = b.rFrac * maxDim * pulse;
        const cx = b.ax * W + (reduceMotion ? 0 : b.driftX * Math.sin(t * b.ds * speedMult + b.phase)) + parX * b.depth;
        const cy = b.ay * H + (reduceMotion ? 0 : b.driftY * Math.cos(t * b.ds * speedMult * 1.3 + b.phase)) + parY * b.depth;
        const a = b.alpha * (reduceMotion ? 1 : 0.78 + 0.22 * Math.sin(t * b.ps * speedMult + b.phase));
        const g = ctx!.createRadialGradient(cx, cy, 0, cx, cy, r);
        g.addColorStop(0, `rgba(${b.color}, ${a})`);
        g.addColorStop(0.5, `rgba(${b.color}, ${a * 0.4})`);
        g.addColorStop(1, `rgba(${b.color}, 0)`);
        ctx!.fillStyle = g;
        ctx!.beginPath();
        ctx!.arc(cx, cy, r, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalCompositeOperation = 'source-over';
    }

    function drawDust(t: number) {
      for (const d of dust) {
        const tw = reduceMotion ? 1 : 0.6 + 0.4 * Math.sin(t * 0.001 * d.tw + d.ph);
        ctx!.globalAlpha = d.a * tw;
        ctx!.fillStyle = '#eaf6ff';
        ctx!.beginPath();
        ctx!.arc(d.x + parX * 1.2, d.y + parY * 1.2, d.r, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalAlpha = 1;
    }

    function update() {
      parX += (tgtX - parX) * 0.03;
      parY += (tgtY - parY) * 0.03;
      for (const d of dust) {
        d.x += d.vx;
        d.y += d.vy;
        if (d.x < 0) d.x = W; else if (d.x > W) d.x = 0;
        if (d.y < 0) d.y = H; else if (d.y > H) d.y = 0;
      }
    }

    function draw(t: number) {
      ctx!.clearRect(0, 0, W, H);
      drawBlobs(t);
      drawDust(t);
    }

    function frame(t: number) {
      if (!running) return;
      if (window.scrollY < window.innerHeight * 1.15) {
        update();
        draw(t);
      }
      requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize);
    window.addEventListener('mousemove', (e) => {
      tgtX = (e.clientX / window.innerWidth - 0.5) * -50; // parallax máx ±25px
      tgtY = (e.clientY / window.innerHeight - 0.5) * -50;
    });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        running = false;
      } else if (!reduceMotion) {
        running = true;
        requestAnimationFrame(frame);
      }
    });

    resize();
    if (reduceMotion) draw(0);
    else requestAnimationFrame(frame);
  })();
</script>
