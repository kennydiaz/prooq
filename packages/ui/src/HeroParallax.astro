---
export interface HeroCta {
  label: string;
  href: string;
}

export interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  cta?: HeroCta;
  bgImage?: string;
}

const { title, subtitle, description, cta, bgImage } = Astro.props;
---

<section
  class="hero-parallax"
  style={bgImage ? `background-image: url(${bgImage})` : undefined}
  data-has-bg={bgImage ? 'true' : 'false'}
>
  <div class="hero-content">
    <h1 class="hero-title">{title}</h1>
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    {description && <p class="hero-description">{description}</p>}
    {cta && (
      <a href={cta.href} class="hero-cta">
        {cta.label}
      </a>
    )}
    <slot />
  </div>
</section>

<style>
  .hero-parallax {
    position: relative;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-parallax[data-has-bg="true"] {
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-repeat: no-repeat;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--color-text);
    max-width: 800px;
    margin: 180px auto 0;
    padding: 2rem;
    background: rgb(0 0 0 / 0.6);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgb(255 255 255 / 0.1);
    box-shadow: var(--shadow-card);
    animation: hero-fade-in-up 1s ease-out;
  }

  @keyframes hero-fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 700;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 8px rgb(0 0 0 / 0.8);
    letter-spacing: 0.1875rem;
    background: linear-gradient(45deg, #ffffff, var(--color-brand-light));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-brand-light);
    font-weight: 600;
    text-shadow: 1px 1px 3px rgb(0 0 0 / 0.5);
  }

  .hero-description {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    line-height: 1.6;
    color: var(--color-text-soft);
    text-shadow: 1px 1px 2px rgb(0 0 0 / 0.5);
  }

  .hero-cta {
    display: inline-block;
    padding: 0.9375rem 1.875rem;
    background: linear-gradient(45deg, var(--color-brand), var(--color-brand-light));
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: 1.1rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    box-shadow: var(--shadow-cta);
    position: relative;
    overflow: hidden;
  }

  .hero-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgb(255 255 255 / 0.2), transparent);
    transition: left 0.5s ease;
  }

  .hero-cta:hover::before {
    left: 100%;
  }

  .hero-cta:hover,
  .hero-cta:focus-visible {
    transform: translateY(-3px) scale(1.05);
    box-shadow: var(--shadow-cta-hover);
    background: linear-gradient(45deg, var(--color-brand-darker), #3d8cff);
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.5rem; letter-spacing: 0.125rem; }
    .hero-subtitle { font-size: 1.2rem; }
    .hero-description { font-size: 1rem; }
    .hero-content {
      padding: 1.5rem;
      margin: 200px 1rem 0;
      border-radius: var(--radius-md);
    }
    .hero-parallax { min-height: 500px; }
    .hero-cta { padding: 0.75rem 1.5rem; font-size: 1rem; }

    /* En mobile, fixed background suele dar problemas de performance — usa scroll */
    .hero-parallax[data-has-bg="true"] {
      background-attachment: scroll;
    }
  }

  @media (max-width: 480px) {
    .hero-title { font-size: 2rem; letter-spacing: 0.0625rem; }
    .hero-subtitle { font-size: 1.1rem; }
    .hero-description { font-size: 0.9rem; }
    .hero-content { padding: 1rem; margin: 160px 0.5rem 0; }
    .hero-parallax { min-height: 550px; }
    .hero-cta { padding: 0.625rem 1.25rem; font-size: 0.9rem; }
  }
</style>
