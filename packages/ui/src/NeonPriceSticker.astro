---
export interface Props {
  price: string;
  currency?: string;
  label?: string;
  as?: 'span' | 'div';
}

const { price, currency, label, as: Tag = 'span' } = Astro.props;

const display = currency ? `${currency} ${price}` : price;
---

<Tag class="neon-price-sticker">
  {label && <span class="sticker-label">{label}</span>}
  <span class="sticker-price">{display}</span>
</Tag>

<style>
  .neon-price-sticker {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    background: linear-gradient(
      90deg,
      var(--color-brand),
      var(--color-accent-neon),
      var(--color-accent-cyan)
    );
    color: var(--color-surface-deep);
    font-weight: 700;
    padding: 0.5rem 1.75rem;
    border-radius: 1.5rem;
    font-size: 1.08rem;
    letter-spacing: 0.0625rem;
    border: 2px solid var(--color-accent-cyan);
    box-shadow: var(--shadow-neon-cyan);
    text-shadow: 0 0 8px var(--color-accent-cyan), 0 0 2px var(--color-brand);
    animation: neon-price-glow 1.8s infinite alternate;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .neon-price-sticker:hover {
    background: linear-gradient(
      90deg,
      var(--color-accent-neon),
      var(--color-brand),
      var(--color-accent-cyan)
    );
    color: var(--color-text);
    border-color: var(--color-accent-neon-green);
  }

  .sticker-label {
    font-size: 0.7em;
    font-weight: 600;
    opacity: 0.85;
    text-transform: uppercase;
    letter-spacing: 0.075em;
  }

  .sticker-price {
    font-variant-numeric: tabular-nums;
  }

  @keyframes neon-price-glow {
    0%, 100% { box-shadow: var(--shadow-neon-cyan); }
    50%      { box-shadow: var(--shadow-neon-green); }
  }

  @media (prefers-reduced-motion: reduce) {
    .neon-price-sticker {
      animation: none;
    }
  }
</style>
