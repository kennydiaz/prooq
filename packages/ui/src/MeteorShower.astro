---
/**
 * MeteorShower — fondo de "lluvia de meteoros": campo estelar tenue con
 * meteoros/cometas que cruzan en diagonal dejando estelas brillantes, como
 * una lluvia de estrellas desde un radiante común. Dinámico pero limpio.
 * Canvas puro, fallback para reduced-motion, pausa al ocultar la pestaña y al
 * hacer scroll más allá del hero. Capa fija a viewport (z-index -1).
 * Singleton: usar una sola vez por página.
 *
 * Props:
 *   rate — multiplicador de frecuencia de meteoros (1 = por defecto).
 */
export interface Props {
  rate?: number;
}

const { rate = 1 } = Astro.props;
---

<div class="meteor-bg" aria-hidden="true" data-rate={rate}>
  <canvas id="meteor-canvas"></canvas>
</div>

<style>
  .meteor-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 80% 60% at 25% 15%, rgb(20 30 80 / 0.35), transparent 60%),
      radial-gradient(ellipse 70% 55% at 80% 85%, rgb(40 15 70 / 0.3), transparent 58%),
      #03030a;
  }

  #meteor-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  (() => {
    const root = document.querySelector('.meteor-bg') as HTMLElement | null;
    const canvas = document.getElementById('meteor-canvas') as HTMLCanvasElement | null;
    const ctx = canvas?.getContext('2d');
    if (!root || !canvas || !ctx) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const rate = Number(root.dataset.rate) || 1;

    const HEAD_COLORS = ['255, 255, 255', '200, 240, 255', '180, 220, 255', '255, 240, 210'];

    interface Star { x: number; y: number; r: number; a: number; tw: number; ph: number; }
    interface Meteor {
      x: number; y: number; vx: number; vy: number;
      len: number; width: number; color: string;
    }

    let W = 0, H = 0;
    let stars: Star[] = [];
    let meteors: Meteor[] = [];
    let running = true;
    let nextSpawn = 0;
    let parX = 0, parY = 0, tgtX = 0, tgtY = 0;

    const rand = (a: number, b: number) => Math.random() * (b - a) + a;

    function buildStars() {
      const count = Math.min(Math.max(Math.round((W * H) / 8000), 80), 260);
      stars = [];
      for (let i = 0; i < count; i++) {
        stars.push({
          x: rand(0, W),
          y: rand(0, H),
          r: rand(0.4, 1.5),
          a: rand(0.25, 0.85),
          tw: rand(0.5, 2),
          ph: rand(0, Math.PI * 2),
        });
      }
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = window.innerWidth;
      H = window.innerHeight;
      canvas!.width = W * dpr;
      canvas!.height = H * dpr;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildStars();
    }

    function spawnMeteor(big: boolean) {
      // Radiante común arriba-derecha → caen hacia abajo-izquierda.
      const angle = rand(2.32, 2.62); // ~133°-150°: cos<0, sin>0
      const speed = rand(7, 12) * (big ? 1.3 : 1);
      meteors.push({
        x: rand(W * 0.1, W * 1.2),
        y: rand(-H * 0.1, H * 0.5),
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        len: rand(120, 240) * (big ? 1.7 : 1),
        width: big ? rand(2.4, 3.4) : rand(0.9, 1.9),
        color: HEAD_COLORS[(Math.random() * HEAD_COLORS.length) | 0]!,
      });
    }

    function drawStars(t: number) {
      for (const s of stars) {
        const tw = reduceMotion ? 1 : 0.6 + 0.4 * Math.sin(t * 0.001 * s.tw + s.ph);
        ctx!.globalAlpha = s.a * tw;
        ctx!.fillStyle = '#ffffff';
        ctx!.beginPath();
        ctx!.arc(s.x + parX, s.y + parY, s.r, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalAlpha = 1;
    }

    function drawMeteors() {
      for (const m of meteors) {
        const sp = Math.hypot(m.vx, m.vy) || 1;
        const tx = m.x - (m.vx / sp) * m.len;
        const ty = m.y - (m.vy / sp) * m.len;
        // Estela (gradiente cabeza→transparente).
        const g = ctx!.createLinearGradient(m.x, m.y, tx, ty);
        g.addColorStop(0, `rgba(${m.color}, 0.95)`);
        g.addColorStop(0.4, `rgba(${m.color}, 0.35)`);
        g.addColorStop(1, `rgba(${m.color}, 0)`);
        ctx!.strokeStyle = g;
        ctx!.lineWidth = m.width;
        ctx!.lineCap = 'round';
        ctx!.beginPath();
        ctx!.moveTo(m.x, m.y);
        ctx!.lineTo(tx, ty);
        ctx!.stroke();
        // Cabeza con glow.
        ctx!.shadowColor = `rgba(${m.color}, 0.9)`;
        ctx!.shadowBlur = 8;
        ctx!.fillStyle = `rgba(${m.color}, 1)`;
        ctx!.beginPath();
        ctx!.arc(m.x, m.y, m.width * 0.9, 0, Math.PI * 2);
        ctx!.fill();
        ctx!.shadowBlur = 0;
      }
    }

    function update() {
      parX += (tgtX - parX) * 0.04;
      parY += (tgtY - parY) * 0.04;
      for (let i = meteors.length - 1; i >= 0; i--) {
        const m = meteors[i]!;
        m.x += m.vx;
        m.y += m.vy;
        if (m.x < -m.len || m.y > H + m.len) meteors.splice(i, 1);
      }
    }

    function draw(t: number) {
      ctx!.clearRect(0, 0, W, H);
      drawStars(t);
      drawMeteors();
    }

    function frame(t: number) {
      if (!running) return;
      if (window.scrollY < window.innerHeight * 1.15) {
        if (t > nextSpawn) {
          spawnMeteor(Math.random() < 0.12);
          if (Math.random() < 0.4) spawnMeteor(false);
          nextSpawn = t + rand(220, 620) / rate;
        }
        update();
        draw(t);
      }
      requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize);
    window.addEventListener('mousemove', (e) => {
      tgtX = (e.clientX / window.innerWidth - 0.5) * 24; // parallax suave de estrellas
      tgtY = (e.clientY / window.innerHeight - 0.5) * 24;
    });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        running = false;
      } else if (!reduceMotion) {
        running = true;
        requestAnimationFrame(frame);
      }
    });

    resize();
    if (reduceMotion) draw(0);
    else requestAnimationFrame(frame);
  })();
</script>
