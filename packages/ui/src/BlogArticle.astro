---
// Artículo de blog compartido por las apps país. El contenido renderizado del .md
// se pasa por el slot por defecto. Es base-aware (usa BASE_URL de cada app) y localizable.
export interface Props {
  title: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
  /** Locale para fechas y textos de UI, p.ej. 'es-PA', 'es-ES', 'en-US'. */
  locale?: string;
  /** Razón social para el JSON-LD (PROOQ S.A. en PA/ES/VE, PROOQ LLC en USA). */
  orgName?: string;
  /** Imagen por defecto del Article si el .md no trae heroImage. */
  defaultImage?: string;
  description?: string;
}

const {
  title,
  pubDate,
  updatedDate,
  tags = [],
  heroImage,
  locale = 'es-PA',
  orgName = 'PROOQ S.A.',
  defaultImage = '/images/pty.jpg',
  description = '',
} = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const ORIGIN = (Astro.site ?? new URL('https://prooq.com')).origin;
const abs = (path: string) => new URL(path, ORIGIN).href;
const url = abs(Astro.url.pathname.replace(/\/?$/, '/'));
const published = pubDate.toISOString();

const en = locale.startsWith('en');
const t = {
  home: en ? 'Home' : 'Inicio',
  blog: 'Blog',
  updated: en ? 'updated' : 'actualizado',
  back: en ? '← Back to blog' : '← Volver al blog',
  crumbs: en ? 'Breadcrumb' : 'Migas de pan',
};

const fmt = (d: Date) =>
  d.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: published,
  dateModified: (updatedDate ?? pubDate).toISOString(),
  image: abs(heroImage ?? defaultImage),
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  author: { '@type': 'Organization', name: orgName, url: ORIGIN },
  publisher: {
    '@type': 'Organization',
    name: orgName,
    logo: { '@type': 'ImageObject', url: abs('/images/logoblanco.png') },
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.home, item: abs(BASE) },
    { '@type': 'ListItem', position: 2, name: t.blog, item: abs(`${BASE}blog/`) },
    { '@type': 'ListItem', position: 3, name: title, item: url },
  ],
};
---

<article class="section">
  <div class="article-container">
    <nav class="crumbs" aria-label={t.crumbs}>
      <a href={BASE}>{t.home}</a>
      <span aria-hidden="true">/</span>
      <a href={`${BASE}blog`}>{t.blog}</a>
    </nav>

    <header class="article-header">
      <h1 class="article-title">{title}</h1>
      <p class="article-meta">
        <time datetime={published}>{fmt(pubDate)}</time>
        {updatedDate && <span> · {t.updated} {fmt(updatedDate)}</span>}
      </p>
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <span class="article-tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    {heroImage && <img class="article-hero" src={heroImage} alt={title} loading="lazy" />}

    <div class="prose">
      <slot />
    </div>

    <footer class="article-footer">
      <a href={`${BASE}blog`} class="back-link">{t.back}</a>
    </footer>
  </div>
</article>

<script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline />

<style>
  .article-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .crumbs {
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .crumbs a {
    color: var(--color-brand-light);
    text-decoration: none;
  }

  .article-header {
    margin-bottom: 1.5rem;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1.15;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }

  .article-meta {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0 0 0.75rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .article-tag {
    font-size: 0.75rem;
    color: var(--color-brand-light);
    background: rgb(0 60 255 / 0.12);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
  }

  .article-hero {
    width: 100%;
    border-radius: var(--radius-lg);
    margin: 1rem 0 2rem;
  }

  /* Estilos de lectura (sin Tailwind typography — tokens del sistema). */
  .prose {
    color: var(--color-text-soft);
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.5rem;
    margin: 2.25rem 0 0.75rem;
  }

  .prose :global(h3) {
    color: var(--color-text);
    font-size: 1.2rem;
    margin: 1.75rem 0 0.5rem;
  }

  .prose :global(p) {
    margin: 0 0 1.15rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.15rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(a) {
    color: var(--color-accent-cyan);
    text-decoration: underline;
  }

  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 3px solid var(--color-brand-light);
    background: rgb(255 255 255 / 0.03);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    color: var(--color-text-soft);
    font-style: italic;
  }

  .prose :global(strong) {
    color: var(--color-text);
  }

  .article-footer {
    margin: 3rem 0 1rem;
  }

  .back-link {
    color: var(--color-accent-cyan);
    font-weight: 600;
    text-decoration: none;
  }
</style>
