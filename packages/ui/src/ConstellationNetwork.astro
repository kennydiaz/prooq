---
/**
 * ConstellationNetwork — fondo de "red de constelaciones": partículas a la deriva
 * que se conectan con líneas finas cuando están cerca, evocando una red/grafo
 * (encaja con el negocio de redes y conectividad de la sucursal USA).
 * El cursor enlaza y atrae suavemente a las partículas cercanas.
 * Canvas puro, fallback para reduced-motion, pausa al ocultar la pestaña y
 * al hacer scroll más allá del hero. Capa fija a viewport (z-index -1).
 * Singleton: usar una sola vez por página.
 *
 * Props:
 *   density   — multiplicador de cantidad de partículas (1 = por defecto).
 *   linkColor — color de las líneas de enlace (rgb/hex).
 */
export interface Props {
  density?: number;
  linkColor?: string;
}

const { density = 1, linkColor = '0, 198, 231' } = Astro.props;
---

<div class="constellation-bg" aria-hidden="true" data-density={density} data-link={linkColor}>
  <canvas id="constellation-canvas"></canvas>
</div>

<style>
  .constellation-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 80% 60% at 22% 18%, rgb(0 60 255 / 0.16), transparent 60%),
      radial-gradient(ellipse 70% 55% at 82% 80%, rgb(0 198 231 / 0.12), transparent 58%),
      #000000;
  }

  #constellation-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  (() => {
    const root = document.querySelector('.constellation-bg') as HTMLElement | null;
    const canvas = document.getElementById('constellation-canvas') as HTMLCanvasElement | null;
    const ctx = canvas?.getContext('2d');
    if (!root || !canvas || !ctx) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const densityMult = Number(root.dataset.density) || 1;
    const LINK_RGB = root.dataset.link || '0, 198, 231';

    const LINK_DIST = 140; // distancia máx. para enlazar dos partículas
    const MOUSE_DIST = 170; // radio de influencia del cursor

    interface P {
      x: number; y: number; vx: number; vy: number; r: number;
    }

    let W = 0, H = 0;
    let nodes: P[] = [];
    let running = true;
    let mx = -9999, my = -9999;

    const rand = (a: number, b: number) => Math.random() * (b - a) + a;

    function buildNodes() {
      const count = Math.min(Math.max(Math.round((W * H) / 13000 * densityMult), 50), 170);
      nodes = [];
      for (let i = 0; i < count; i++) {
        nodes.push({
          x: rand(0, W),
          y: rand(0, H),
          vx: rand(-0.25, 0.25),
          vy: rand(-0.25, 0.25),
          r: rand(1, 2.4),
        });
      }
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = window.innerWidth;
      H = window.innerHeight;
      canvas!.width = W * dpr;
      canvas!.height = H * dpr;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildNodes();
    }

    function draw() {
      ctx!.clearRect(0, 0, W, H);

      // Enlaces entre partículas cercanas (alpha según distancia).
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i]!;
        for (let j = i + 1; j < nodes.length; j++) {
          const b = nodes[j]!;
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d = Math.hypot(dx, dy);
          if (d < LINK_DIST) {
            ctx!.globalAlpha = (1 - d / LINK_DIST) * 0.5;
            ctx!.strokeStyle = `rgb(${LINK_RGB})`;
            ctx!.lineWidth = 1;
            ctx!.beginPath();
            ctx!.moveTo(a.x, a.y);
            ctx!.lineTo(b.x, b.y);
            ctx!.stroke();
          }
        }
        // Enlace con el cursor.
        const mdx = a.x - mx;
        const mdy = a.y - my;
        const md = Math.hypot(mdx, mdy);
        if (md < MOUSE_DIST) {
          ctx!.globalAlpha = (1 - md / MOUSE_DIST) * 0.7;
          ctx!.strokeStyle = `rgb(${LINK_RGB})`;
          ctx!.lineWidth = 1;
          ctx!.beginPath();
          ctx!.moveTo(a.x, a.y);
          ctx!.lineTo(mx, my);
          ctx!.stroke();
        }
      }

      // Partículas.
      ctx!.globalAlpha = 0.9;
      ctx!.fillStyle = '#cfe9ff';
      for (const n of nodes) {
        ctx!.beginPath();
        ctx!.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx!.fill();
      }
      ctx!.globalAlpha = 1;
    }

    function update() {
      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        // Rebote suave en los bordes.
        if (n.x < 0 || n.x > W) n.vx *= -1;
        if (n.y < 0 || n.y > H) n.vy *= -1;

        // Atracción leve hacia el cursor.
        const dx = mx - n.x;
        const dy = my - n.y;
        const d = Math.hypot(dx, dy);
        if (d < MOUSE_DIST && d > 0.01) {
          const pull = (1 - d / MOUSE_DIST) * 0.04;
          n.x += dx * pull;
          n.y += dy * pull;
        }
      }
    }

    function frame() {
      if (!running) return;
      // Pausa el trabajo si ya se hizo scroll más allá del hero.
      if (window.scrollY < window.innerHeight * 1.15) {
        update();
        draw();
      }
      requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize);
    window.addEventListener('mousemove', (e) => {
      mx = e.clientX;
      my = e.clientY;
    });
    window.addEventListener('mouseout', () => {
      mx = -9999;
      my = -9999;
    });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        running = false;
      } else if (!reduceMotion) {
        running = true;
        requestAnimationFrame(frame);
      }
    });

    resize();
    if (reduceMotion) draw();
    else requestAnimationFrame(frame);
  })();
</script>
