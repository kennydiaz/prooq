---

<BaseLayout
  title="PROOQ Venezuela — Tecnología y Soluciones Digitales | Puerto La Cruz"
  description="PROOQ S.A. — Especialistas en redes, seguridad digital, software y automatización en Venezuela. Fundada en 1999."
>
  <HeroParallax
    title="PROOQ"
    subtitle="Soluciones tecnológicas integrales para empresas"
    description="Especialistas en cableado estructurado, seguridad electrónica y automatización empresarial en Venezuela"
    cta={{ label: 'Conoce nuestros servicios', href: '#servicios' }}
  >
    <div class="hero-extras">
      <a href="#contact" class="cta-secondary">Contáctanos</a>
      <p class="hero-location">📍 Puerto La Cruz, Venezuela 🇻🇪</p>
    </div>
  </HeroParallax>

  <section id="servicios" class="section section-services">
    <div class="section-container">
      <h2 class="section-title fade-in">Servicios Especiales</h2>
      <p class="section-subtitle fade-in">Soluciones tecnológicas integrales para empresas modernas</p>
      <div class="services-grid">
        {services.map((s) => (
          <article class="service-card fade-in">
            <div class="service-icon" aria-hidden="true">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <ul>
              {s.features.map((f) => <li>{f}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-about">
    <div class="section-container">
      <div class="about-grid">
        <div class="fade-in">
          <h2 class="section-title">Sobre PROOQ S.A.</h2>
          <p>
            PROOQ S.A. es una empresa líder en cableado estructurado, seguridad electrónica
            y automatización de sistemas empresariales. Fundada en Venezuela en 1999, nos
            especializamos en ofrecer soluciones tecnológicas integrales para mejorar la
            eficiencia y seguridad de negocios en diversos sectores.
          </p>
          <p>
            Más de dos décadas acompañando a empresas venezolanas con servicios de redes,
            telecomunicaciones, ciberseguridad y consultoría técnica.
          </p>
          <div class="stats">
            {stats.map((s) => (
              <div class="stat">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="equipo" class="section section-team">
    <div class="section-container">
      <h2 class="section-title fade-in">Nuestro Equipo</h2>
      <p class="section-subtitle fade-in">Profesionales comprometidos con la calidad técnica</p>
      <div class="team-grid">
        {team.map((m) => (
          <article class="team-member fade-in">
            <img src={m.photo} alt={m.name} loading="lazy" />
            <h3>{m.name}</h3>
            <p>{m.role}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="portafolio" class="section section-portfolio">
    <div class="section-container">
      <h2 class="section-title fade-in">Portafolio de Sitios Web Desarrollados</h2>
      <p class="section-subtitle fade-in">
        Una selección de sitios web diseñados y desarrollados por nuestro equipo. Cada proyecto
        refleja nuestro compromiso con la innovación, la calidad y la excelencia tecnológica.
      </p>
      <div class="portfolio-grid">
        {portfolio.map((p) => (
          <article class="portfolio-card fade-in">
            <h3>{p.name}</h3>
            <p>{p.description}</p>
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="portfolio-link">
              Visitar sitio →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="ubicacion" class="section section-location">
    <div class="section-container">
      <div class="location-grid">
        <div class="fade-in">
          <h2 class="section-title">Ubicados en Puerto La Cruz</h2>
          <p>
            Desde Puerto La Cruz, servimos a empresas en toda Venezuela con soluciones
            tecnológicas de vanguardia y soporte técnico especializado.
          </p>
          <div class="location-details">
            {locationDetails.map((d) => (
              <div class="location-detail">
                <span class="detail-icon" aria-hidden="true">{d.icon}</span>
                <div>
                  <h4>{d.title}</h4>
                  <p>{d.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Fade-in al scroll — IntersectionObserver replicado del V1.
  const elements = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' },
  );

  for (const el of elements) observer.observe(el);
</script>
