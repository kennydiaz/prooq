---
import '@prooq/styles/globals.css';
import '@prooq/styles/sections.css';
import { CountriesMenu, Footer, Header, Seo, VisitTracker } from '@prooq/ui';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
}

const { title, description, image, type, publishedDate } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo
      site="ven"
      {title}
      description={description ?? title}
      {image}
      {type}
      {publishedDate}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Orbitron:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header country="ven" logoSrc={`${BASE}images/logoblanco.png`} logoAlt="PROOQ Venezuela">
      <CountriesMenu slot="countries-menu" current="ven" />
    </Header>
    <main>
      <slot />
    </main>
    <Footer
      country="ven"
      contact={{
        email: 'info@prooq.com',
        phone: '+58 424-8820040',
        whatsapp: '+58 424-8820040',
        address: 'Puerto La Cruz, Venezuela',
      }}
    />
    <VisitTracker site="ven" />
  </body>
</html>
