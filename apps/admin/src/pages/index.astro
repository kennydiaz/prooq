---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Galería">
  <div class="page-head">
    <h1>Galería</h1>
    <p class="page-sub">Subí, organizá y publicá las imágenes que aparecen en las páginas <code>/gallery</code> de cada sucursal.</p>
  </div>

  <section class="card upload-card">
    <h2>Subir imagen</h2>
    <form id="upload-form" autocomplete="off">
      <div class="grid-2">
        <label class="full">
          <span>Archivo (JPG/PNG/WEBP/GIF, máx 10MB)</span>
          <input type="file" name="image" accept="image/jpeg,image/png,image/webp,image/gif" required />
        </label>

        <label>
          <span>País (vacío = global, visible en las 4 sucursales)</span>
          <select name="country">
            <option value="">— Global —</option>
            <option value="PA">Panamá (PA)</option>
            <option value="US">USA (US)</option>
            <option value="ES">España (ES)</option>
            <option value="VE">Venezuela (VE)</option>
          </select>
        </label>

        <label>
          <span>Orden (0 = primero)</span>
          <input type="number" name="display_order" value="0" min="0" />
        </label>

        <label class="full">
          <span>Título (opcional)</span>
          <input type="text" name="title" />
        </label>

        <label class="full">
          <span>Texto alternativo (alt) — recomendado para accesibilidad</span>
          <input type="text" name="alt" />
        </label>

        <label class="full">
          <span>Caption (opcional)</span>
          <input type="text" name="caption" />
        </label>
      </div>

      <button type="submit" id="upload-btn">Subir</button>
      <p class="upload-status" id="upload-status" aria-live="polite"></p>
    </form>
  </section>

  <section class="card">
    <div class="list-head">
      <h2>Imágenes publicadas</h2>
      <button type="button" id="refresh-btn" class="ghost-btn">Refrescar</button>
    </div>
    <div id="items-grid" class="items-grid">
      <p class="muted">Cargando…</p>
    </div>
  </section>
</AdminLayout>

<script>
  import {
    deleteGalleryItem,
    getAdminGallery,
    uploadGalleryImage,
    type GalleryItem,
  } from '@prooq/data-client/gallery';

  const grid = document.getElementById('items-grid');
  const refreshBtn = document.getElementById('refresh-btn');
  const form = document.getElementById('upload-form') as HTMLFormElement | null;
  const status = document.getElementById('upload-status');
  const uploadBtn = document.getElementById('upload-btn') as HTMLButtonElement | null;

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[c] ?? c);
  }

  function fmtSize(bytes: number | null): string {
    if (bytes === null) return '';
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
    return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  }

  function renderItem(it: GalleryItem): string {
    const country = it.country ?? 'Global';
    const dims = it.widthPx && it.heightPx ? `${it.widthPx}×${it.heightPx}` : '';
    const title = it.title ?? '(sin título)';
    return `
      <article class="item" data-id="${it.id}">
        <div class="item-thumb">
          <img src="${escapeHtml(it.url)}" alt="${escapeHtml(it.alt ?? title)}" loading="lazy" />
        </div>
        <div class="item-body">
          <strong>${escapeHtml(title)}</strong>
          <div class="item-meta">
            <span class="badge">${escapeHtml(country)}</span>
            <span>${dims}</span>
            <span>${fmtSize(it.fileSizeBytes)}</span>
            <span>Orden ${it.displayOrder}</span>
            ${it.isPublic ? '' : '<span class="badge warn">No público</span>'}
          </div>
        </div>
        <button type="button" class="del-btn" data-id="${it.id}">Borrar</button>
      </article>
    `;
  }

  async function loadGrid(): Promise<void> {
    if (!grid) return;
    grid.innerHTML = '<p class="muted">Cargando…</p>';
    try {
      const items = await getAdminGallery();
      if (items.length === 0) {
        grid.innerHTML = '<p class="muted">No hay imágenes todavía. Subí la primera arriba.</p>';
        return;
      }
      grid.innerHTML = items.map(renderItem).join('');

      grid.querySelectorAll<HTMLButtonElement>('.del-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = Number(btn.dataset.id);
          if (!Number.isFinite(id)) return;
          if (!confirm('¿Borrar esta imagen? Esta acción es irreversible.')) return;
          btn.disabled = true;
          btn.textContent = 'Borrando…';
          try {
            await deleteGalleryItem(id);
            await loadGrid();
          } catch (err) {
            console.error(err);
            alert('No se pudo borrar.');
            btn.disabled = false;
            btn.textContent = 'Borrar';
          }
        });
      });
    } catch (err) {
      console.error(err);
      grid.innerHTML = '<p class="muted error">Error cargando galería.</p>';
    }
  }

  refreshBtn?.addEventListener('click', loadGrid);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !status || !uploadBtn) return;

    const fd = new FormData(form);
    const file = fd.get('image');
    if (!(file instanceof File) || file.size === 0) {
      status.textContent = 'Seleccioná un archivo.';
      return;
    }

    const countryRaw = String(fd.get('country') ?? '');
    const country =
      countryRaw === 'PA' || countryRaw === 'US' || countryRaw === 'ES' || countryRaw === 'VE'
        ? countryRaw
        : undefined;

    status.textContent = 'Subiendo…';
    uploadBtn.disabled = true;

    try {
      await uploadGalleryImage(file, {
        title: String(fd.get('title') ?? '').trim() || undefined,
        alt: String(fd.get('alt') ?? '').trim() || undefined,
        caption: String(fd.get('caption') ?? '').trim() || undefined,
        country,
        displayOrder: Number(fd.get('display_order') ?? 0),
      });
      form.reset();
      status.textContent = '✔ Subida exitosa';
      await loadGrid();
    } catch (err) {
      console.error(err);
      status.textContent = '✗ Error: ' + (err instanceof Error ? err.message : 'desconocido');
    } finally {
      uploadBtn.disabled = false;
    }
  });

  loadGrid();
</script>

<style>
  .page-head {
    margin-bottom: 2rem;
  }

  .page-head h1 {
    font-family: var(--font-display);
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
  }

  .page-sub {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
  }

  .page-sub code {
    background: rgb(0 198 231 / 0.1);
    color: var(--color-accent-cyan);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
    font-size: 0.85em;
  }

  .card {
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .card h2 {
    margin: 0 0 1rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .upload-card .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .upload-card .grid-2 .full {
    grid-column: 1 / -1;
  }

  label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label span {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  input, select {
    background: var(--color-surface);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-md);
    padding: 0.55rem 0.75rem;
    color: var(--color-text);
    font: inherit;
  }

  input:focus, select:focus {
    outline: none;
    border-color: var(--color-accent-cyan);
  }

  button[type="submit"] {
    background: var(--color-brand);
    color: var(--color-text);
    border: none;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
  }

  button[type="submit"]:hover:not(:disabled) {
    background: var(--color-brand-darker);
  }

  button[type="submit"]:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .ghost-btn {
    background: transparent;
    border: 1px solid rgb(255 255 255 / 0.2);
    color: var(--color-text-soft);
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
  }

  .ghost-btn:hover {
    background: rgb(255 255 255 / 0.06);
  }

  .upload-status {
    margin: 0.75rem 0 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .list-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .list-head h2 {
    margin: 0;
  }

  .items-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .item {
    background: var(--color-surface);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .item-thumb {
    aspect-ratio: 16 / 10;
    background: #000;
    overflow: hidden;
  }

  .item-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .item-body {
    padding: 0.75rem 0.9rem;
    flex: 1;
  }

  .item-body strong {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
  }

  .item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .badge {
    background: rgb(0 60 255 / 0.2);
    color: var(--color-brand-light);
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .badge.warn {
    background: rgb(255 179 0 / 0.2);
    color: var(--color-accent-amber);
  }

  .del-btn {
    background: transparent;
    border: none;
    border-top: 1px solid rgb(255 255 255 / 0.06);
    color: #ff9090;
    padding: 0.6rem;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .del-btn:hover:not(:disabled) {
    background: rgb(255 100 100 / 0.08);
  }

  .del-btn:disabled {
    opacity: 0.5;
  }

  .muted {
    color: var(--color-text-muted);
    text-align: center;
    padding: 1.5rem;
    margin: 0;
  }

  .muted.error {
    color: #ff8080;
  }

  @media (max-width: 600px) {
    .upload-card .grid-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
