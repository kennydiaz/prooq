---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
  <div class="page-head">
    <div>
      <h1>Dashboard</h1>
      <p class="page-sub">Visitas registradas en las páginas públicas — IPs y país de origen. Más métricas se irán sumando por módulos.</p>
    </div>
    <button type="button" id="refresh-btn" class="ghost-btn">↻ Actualizar</button>
  </div>

  <!-- KPIs -->
  <section class="kpis" aria-label="Indicadores principales">
    <article class="kpi"><span class="kpi-label">Visitas totales</span><strong class="kpi-value" id="kpi-total">—</strong></article>
    <article class="kpi"><span class="kpi-label">Hoy</span><strong class="kpi-value" id="kpi-today">—</strong></article>
    <article class="kpi"><span class="kpi-label">Últimos 7 días</span><strong class="kpi-value" id="kpi-last7">—</strong></article>
    <article class="kpi"><span class="kpi-label">IPs únicas</span><strong class="kpi-value" id="kpi-ips">—</strong></article>
    <article class="kpi"><span class="kpi-label">Países</span><strong class="kpi-value" id="kpi-countries">—</strong></article>
    <article class="kpi"><span class="kpi-label">País top</span><strong class="kpi-value" id="kpi-top">—</strong></article>
  </section>

  <!-- Gráficas -->
  <section class="charts">
    <div class="card chart-card">
      <h2>Visitas por día <span class="muted-inline">(últimos 14 días)</span></h2>
      <div class="chart-wrap"><canvas id="chart-timeseries"></canvas></div>
    </div>
    <div class="card chart-card">
      <h2>Visitas por país</h2>
      <div class="chart-wrap"><canvas id="chart-country"></canvas></div>
    </div>
  </section>

  <!-- Visitas recientes -->
  <section class="card">
    <h2>Visitas recientes</h2>
    <div class="table-wrap">
      <table class="visits-table">
        <thead>
          <tr><th>País</th><th>IP</th><th>Ruta</th><th>Sitio</th><th>Fecha</th></tr>
        </thead>
        <tbody id="visits-body">
          <tr><td colspan="5" class="muted">Cargando…</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</AdminLayout>

<script>
  import { Chart } from 'chart.js/auto';
  import {
    getRecentVisits,
    getVisitsByCountry,
    getVisitsSummary,
    getVisitsTimeseries,
  } from '@prooq/data-client/stats';

  const BRAND = '#00c6e7';
  const PALETTE = ['#00c6e7', '#3b82f6', '#8b5cf6', '#ec4899', '#22c55e', '#f59e0b', '#ef4444', '#14b8a6'];

  // ISO-2 -> emoji bandera (🌐 si desconocido).
  function flag(cc: string | null): string {
    if (!cc || cc.length !== 2 || cc === '??') return '🌐';
    const base = 0x1f1e6;
    return String.fromCodePoint(base + cc.charCodeAt(0) - 65, base + cc.charCodeAt(1) - 65);
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] ?? c);
  }

  function fmtDate(iso: string): string {
    const d = new Date(iso.replace(' ', 'T'));
    return Number.isNaN(d.getTime()) ? iso : d.toLocaleString('es', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
  }

  const setText = (id: string, v: string | number) => {
    const el = document.getElementById(id);
    if (el) el.textContent = String(v);
  };

  let tsChart: Chart | null = null;
  let ccChart: Chart | null = null;

  async function load(): Promise<void> {
    const [summary, series, byCountry, recent] = await Promise.all([
      getVisitsSummary(),
      getVisitsTimeseries(14),
      getVisitsByCountry(8),
      getRecentVisits(50),
    ]);

    // KPIs
    setText('kpi-total', summary.total.toLocaleString('es'));
    setText('kpi-today', summary.today.toLocaleString('es'));
    setText('kpi-last7', summary.last7.toLocaleString('es'));
    setText('kpi-ips', summary.uniqueIps.toLocaleString('es'));
    setText('kpi-countries', summary.countries);
    setText('kpi-top', summary.topCountry ? `${flag(summary.topCountry.country)} ${summary.topCountry.country}` : '—');

    // Línea: visitas por día
    const tsEl = document.getElementById('chart-timeseries') as HTMLCanvasElement | null;
    if (tsEl) {
      tsChart?.destroy();
      tsChart = new Chart(tsEl, {
        type: 'line',
        data: {
          labels: series.map((p) => p.date.slice(5)),
          datasets: [{
            label: 'Visitas',
            data: series.map((p) => p.count),
            borderColor: BRAND,
            backgroundColor: 'rgba(0, 198, 231, 0.15)',
            fill: true,
            tension: 0.35,
            pointRadius: 2,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#9aa7b8' } },
            y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#9aa7b8', precision: 0 } },
          },
        },
      });
    }

    // Doughnut: por país
    const ccEl = document.getElementById('chart-country') as HTMLCanvasElement | null;
    if (ccEl) {
      ccChart?.destroy();
      ccChart = new Chart(ccEl, {
        type: 'doughnut',
        data: {
          labels: byCountry.map((c) => `${flag(c.country)} ${c.country}`),
          datasets: [{ data: byCountry.map((c) => c.count), backgroundColor: PALETTE, borderWidth: 0 }],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { position: 'right', labels: { color: '#cfd8e3', boxWidth: 12 } } },
        },
      });
    }

    // Tabla recientes
    const body = document.getElementById('visits-body');
    if (body) {
      body.innerHTML = recent.length === 0
        ? '<tr><td colspan="5" class="muted">Sin visitas registradas todavía.</td></tr>'
        : recent.map((v) => `
            <tr>
              <td>${flag(v.country)} ${v.country ?? '—'}</td>
              <td class="mono">${escapeHtml(v.ip ?? '—')}</td>
              <td class="mono">${escapeHtml(v.path)}</td>
              <td>${escapeHtml(v.site ?? '—')}</td>
              <td>${fmtDate(v.createdAt)}</td>
            </tr>`).join('');
    }
  }

  const refreshBtn = document.getElementById('refresh-btn');
  refreshBtn?.addEventListener('click', () => { void load(); });

  load().catch((err) => {
    console.error(err);
    const body = document.getElementById('visits-body');
    if (body) body.innerHTML = '<tr><td colspan="5" class="muted error">Error cargando estadísticas.</td></tr>';
  });
</script>

<style>
  .page-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .page-head h1 {
    font-family: var(--font-display);
    margin: 0 0 0.5rem;
    font-size: 1.75rem;
  }

  .page-sub {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
    max-width: 640px;
  }

  /* KPIs */
  .kpis {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .kpi {
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-left: 3px solid var(--color-accent-cyan);
    border-radius: var(--radius-lg);
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .kpi-label {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .kpi-value {
    font-family: var(--font-display);
    font-size: 1.9rem;
    line-height: 1;
    color: var(--color-text);
  }

  /* Charts */
  .charts {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .card {
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .card h2 {
    margin: 0 0 1rem;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .muted-inline {
    color: var(--color-text-muted);
    font-weight: 400;
    font-size: 0.85rem;
  }

  .chart-card { margin-bottom: 0; }

  .chart-wrap {
    position: relative;
    height: 280px;
  }

  /* Tabla */
  .table-wrap { overflow-x: auto; }

  .visits-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .visits-table th {
    text-align: left;
    color: var(--color-text-muted);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.08);
  }

  .visits-table td {
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid rgb(255 255 255 / 0.04);
    color: var(--color-text-soft);
  }

  .visits-table tbody tr:hover {
    background: rgb(255 255 255 / 0.03);
  }

  .mono {
    font-family: ui-monospace, 'Cascadia Code', Consolas, monospace;
    font-size: 0.82rem;
  }

  .ghost-btn {
    background: transparent;
    border: 1px solid rgb(255 255 255 / 0.2);
    color: var(--color-text-soft);
    padding: 0.45rem 0.95rem;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ghost-btn:hover { background: rgb(255 255 255 / 0.06); }

  .muted { color: var(--color-text-muted); text-align: center; padding: 1.5rem; }
  .muted.error { color: #ff8080; }

  @media (max-width: 860px) {
    .charts { grid-template-columns: 1fr; }
  }
</style>
