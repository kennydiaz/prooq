---
import '@prooq/styles/globals.css';

export interface Props {
  title: string;
  hideNav?: boolean;
  requireAuth?: boolean;
}

const { title, hideNav = false, requireAuth = true } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — PROOQ Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Orbitron:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {!hideNav && (
      <header class="admin-header">
        <div class="admin-header-inner">
          <a href={BASE} class="admin-brand">
            <span class="admin-brand-mark">PROOQ</span>
            <span class="admin-brand-tag">admin</span>
          </a>
          <nav class="admin-nav">
            <a href={BASE}>Galería</a>
            <button type="button" id="logout-btn" class="logout-btn">Salir</button>
          </nav>
        </div>
      </header>
    )}
    <main class={hideNav ? 'admin-main center' : 'admin-main'}>
      <slot />
    </main>

    <script is:inline define:vars={{ BASE }}>
      // Expone BASE al codigo cliente sin hardcodearlo. AdminLayout siempre
      // monta esto antes que cualquier <script type=module> bundleado por Astro.
      window.__ADMIN_BASE__ = BASE;
    </script>

    {requireAuth && (
      <script>
        import { getMe } from '@prooq/data-client/gallery';

        // Gate de autenticacion en el cliente. Las paginas del admin son HTML
        // estatico — la sesion vive en cookie httponly. Si no hay sesion, redirige.
        const BASE = window.__ADMIN_BASE__ ?? '/admin/';
        try {
          const me = await getMe();
          if (!me.authenticated) window.location.href = BASE + 'login';
        } catch {
          window.location.href = BASE + 'login';
        }
      </script>
    )}

    <script>
      import { adminLogout } from '@prooq/data-client/gallery';
      const BASE = window.__ADMIN_BASE__ ?? '/admin/';
      const logoutBtn = document.getElementById('logout-btn');
      logoutBtn?.addEventListener('click', async () => {
        await adminLogout();
        window.location.href = BASE + 'login';
      });
    </script>

    <style is:global>
      body {
        background: var(--color-surface);
        color: var(--color-text);
        min-height: 100vh;
      }

      .admin-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgb(5 13 31 / 0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgb(255 255 255 / 0.06);
      }

      .admin-header-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .admin-brand {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        text-decoration: none;
      }

      .admin-brand-mark {
        font-family: var(--font-display);
        font-weight: 700;
        color: var(--color-text);
        letter-spacing: 0.05em;
        font-size: 1.25rem;
      }

      .admin-brand-tag {
        font-size: 0.75rem;
        color: var(--color-accent-cyan);
        text-transform: uppercase;
        letter-spacing: 0.15em;
      }

      .admin-nav {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .admin-nav a {
        color: var(--color-text-soft);
        font-size: 0.9rem;
        padding: 0.4rem 0.8rem;
        border-radius: var(--radius-md);
      }

      .admin-nav a:hover {
        background: rgb(255 255 255 / 0.06);
      }

      .logout-btn {
        background: transparent;
        border: 1px solid rgb(255 255 255 / 0.2);
        color: var(--color-text-soft);
        padding: 0.4rem 0.9rem;
        border-radius: var(--radius-md);
        font-size: 0.85rem;
        font-weight: 500;
      }

      .logout-btn:hover {
        background: rgb(255 255 255 / 0.06);
        border-color: rgb(255 255 255 / 0.35);
      }

      .admin-main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      .admin-main.center {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 0px);
        padding-top: 0;
      }
    </style>
  </body>
</html>
