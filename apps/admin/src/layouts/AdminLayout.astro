---
import '@prooq/styles/globals.css';

export interface Props {
  title: string;
  hideNav?: boolean;
  requireAuth?: boolean;
}

const { title, hideNav = false, requireAuth = true } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');

// Modulos del panel. Para agregar uno nuevo, basta sumarlo aqui y crear su
// pagina en src/pages/. El estado activo se calcula contra la URL actual.
const base = BASE.replace(/\/$/, ''); // "/admin"
const path = Astro.url.pathname.replace(/\/$/, '') || base;
const modules = [
  { href: BASE, label: 'Dashboard', icon: '📊', active: path === base },
  { href: `${base}/gallery`, label: 'Galería', icon: '🖼️', active: path === `${base}/gallery` },
  { href: `${base}/team`, label: 'Equipo', icon: '👥', active: path === `${base}/team` },
  {
    href: `${base}/downloads`,
    label: 'Descargas',
    icon: '📥',
    active: path === `${base}/downloads`,
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — PROOQ Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Orbitron:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {
      hideNav ? (
        <main class="admin-main center">
          <slot />
        </main>
      ) : (
        <div class="admin-layout">
          <aside class="admin-sidebar">
            <a href={BASE} class="admin-brand">
              <span class="admin-brand-mark">PROOQ</span>
              <span class="admin-brand-tag">admin</span>
            </a>
            <nav class="admin-nav">
              {modules.map((m) => (
                <a href={m.href} class={m.active ? 'nav-link active' : 'nav-link'}>
                  <span class="nav-icon" aria-hidden="true">
                    {m.icon}
                  </span>
                  <span>{m.label}</span>
                </a>
              ))}
            </nav>
            <button type="button" id="logout-btn" class="logout-btn">
              Salir
            </button>
          </aside>
          <main class="admin-main">
            <slot />
          </main>
        </div>
      )
    }

    <script is:inline define:vars={{ BASE, requireAuth }}>
      // Inline script: corre sincrono ANTES de los <script type=module> bundlados
      // por Astro. Setea el BASE y, opcionalmente, una bandera para saltarse el
      // auth check (necesaria en la pagina /login para evitar redirect loop).
      // El condicional de Astro `{requireAuth && <script>}` NO impide que Astro
      // bundee el script — por eso la bandera runtime es la unica forma robusta.
      window.__ADMIN_BASE__ = BASE;
      window.__SKIP_AUTH_CHECK__ = !requireAuth;
    </script>

    <script>
      import { getMe } from '@prooq/data-client/gallery';

      // Gate de auth en cliente. Las paginas del admin son HTML estatico — la
      // sesion vive en cookie httponly. Si no hay sesion, redirige a login.
      if (!window.__SKIP_AUTH_CHECK__) {
        const BASE = window.__ADMIN_BASE__ ?? '/admin/';
        try {
          const me = await getMe();
          if (!me.authenticated) window.location.href = BASE + 'login';
        } catch {
          window.location.href = BASE + 'login';
        }
      }
    </script>

    <script>
      import { adminLogout } from '@prooq/data-client/gallery';
      const BASE = window.__ADMIN_BASE__ ?? '/admin/';
      const logoutBtn = document.getElementById('logout-btn');
      logoutBtn?.addEventListener('click', async () => {
        await adminLogout();
        window.location.href = BASE + 'login';
      });
    </script>

    <style is:global>
      body {
        background: var(--color-surface);
        color: var(--color-text);
        min-height: 100vh;
      }

      .admin-layout {
        display: flex;
        min-height: 100vh;
      }

      /* Sidebar izquierdo */
      .admin-sidebar {
        width: 240px;
        flex-shrink: 0;
        position: sticky;
        top: 0;
        height: 100vh;
        background: rgb(5 13 31 / 0.95);
        border-right: 1px solid rgb(255 255 255 / 0.06);
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding: 1.25rem 1rem;
      }

      .admin-brand {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        text-decoration: none;
        padding: 0.5rem 0.75rem 1.25rem;
      }

      .admin-brand-mark {
        font-family: var(--font-display);
        font-weight: 700;
        color: var(--color-text);
        letter-spacing: 0.05em;
        font-size: 1.25rem;
      }

      .admin-brand-tag {
        font-size: 0.7rem;
        color: var(--color-accent-cyan);
        text-transform: uppercase;
        letter-spacing: 0.15em;
      }

      .admin-nav {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }

      .nav-link {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        color: var(--color-text-soft);
        font-size: 0.92rem;
        padding: 0.6rem 0.8rem;
        border-radius: var(--radius-md);
        transition: background 0.2s, color 0.2s;
      }

      .nav-link:hover {
        background: rgb(255 255 255 / 0.06);
      }

      .nav-link.active {
        background: rgb(0 198 231 / 0.12);
        color: var(--color-accent-cyan);
        font-weight: 600;
      }

      .nav-icon {
        font-size: 1.05rem;
        width: 1.4rem;
        text-align: center;
      }

      .logout-btn {
        margin-top: auto;
        background: transparent;
        border: 1px solid rgb(255 255 255 / 0.2);
        color: var(--color-text-soft);
        padding: 0.55rem 0.9rem;
        border-radius: var(--radius-md);
        font-size: 0.85rem;
        font-weight: 500;
        text-align: left;
        cursor: pointer;
      }

      .logout-btn:hover {
        background: rgb(255 255 255 / 0.06);
        border-color: rgb(255 255 255 / 0.35);
      }

      .admin-main {
        flex: 1;
        min-width: 0;
        padding: 2rem 2.5rem;
      }

      /* Login: sin sidebar, card centrado a pantalla completa */
      .admin-main.center {
        max-width: none;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 1.5rem;
      }

      /* Responsive: el sidebar pasa a barra superior */
      @media (max-width: 768px) {
        .admin-layout {
          flex-direction: column;
        }

        .admin-sidebar {
          width: auto;
          height: auto;
          position: static;
          flex-direction: row;
          align-items: center;
          flex-wrap: wrap;
          gap: 0.5rem;
          padding: 0.75rem 1rem;
        }

        .admin-brand {
          padding: 0 0.75rem 0 0.25rem;
        }

        .admin-nav {
          flex-direction: row;
          flex-wrap: wrap;
        }

        .logout-btn {
          margin-top: 0;
          margin-left: auto;
        }

        .admin-main {
          padding: 1.5rem 1.25rem;
        }
      }
    </style>
  </body>
</html>
