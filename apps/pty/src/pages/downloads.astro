---
import { type Download, getDownloadFileUrl, getDownloads } from '@prooq/data-client/downloads';
import BaseLayout from '../layouts/BaseLayout.astro';

let downloads: readonly Download[] = [];
try {
  downloads = await getDownloads({ country: 'PA' });
} catch (err) {
  console.warn('[downloads] getDownloads failed:', err);
}

const fmtSize = (bytes: number | null): string => {
  if (bytes === null || bytes === 0) return '';
  const mb = bytes / (1024 * 1024);
  return mb < 1 ? `${Math.round(bytes / 1024)} KB` : `${mb.toFixed(0)} MB`;
};

const isPortal = (d: Download): boolean => d.externalUrl !== null && d.externalUrl !== '';
---

<BaseLayout
  title="Descargas — PROOQ Panamá"
  description="Centro de descargas de PROOQ: software de asistencia remota, sistemas administrativos, utilidades CCTV y portales de licenciamiento."
>
  <section class="section section-services downloads-page">
    <div class="section-container">
      <h1 class="section-title fade-in">Descargas</h1>
      <p class="section-subtitle fade-in">
        Software y portales recomendados por PROOQ — herramientas listas para usar y enlaces directos a las plataformas de tus licencias.
      </p>

      <div class="downloads-grid">
        {downloads.map((d) => {
          const portal = isPortal(d);
          const href = portal ? d.externalUrl! : getDownloadFileUrl(d.slug ?? d.id);
          return (
            <a
              href={href}
              target={portal ? '_blank' : undefined}
              rel={portal ? 'noopener noreferrer' : undefined}
              class={`dl-card fade-in${portal ? ' is-portal' : ''}`}
            >
              {d.iconUrl && (
                <div class="dl-icon">
                  <img src={d.iconUrl} alt={d.title} loading="lazy" />
                </div>
              )}
              <div class="dl-body">
                <h3>{d.title}</h3>
                <p>{d.description}</p>
              </div>
              <div class="dl-footer">
                {portal ? (
                  <span class="dl-badge portal">Portal ↗</span>
                ) : (
                  <>
                    <span class="dl-badge download">↓ Descargar</span>
                    {d.fileSizeBytes && <span class="dl-size">{fmtSize(d.fileSizeBytes)}</span>}
                  </>
                )}
              </div>
            </a>
          );
        })}
      </div>

      <aside class="downloads-note fade-in">
        <p>
          Los archivos descargables son ejecutables Windows (<code>.exe</code>). Si tu navegador
          alerta sobre seguridad al descargar, es normal — los archivos son herramientas técnicas
          legítimas distribuidas por sus fabricantes oficiales. Si tenés dudas, contáctanos.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .downloads-page {
    padding-top: 8rem;
  }

  .downloads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .dl-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.25rem 1.25rem;
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .dl-card:hover,
  .dl-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgb(0 198 231 / 0.4);
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.35);
  }

  .dl-card.is-portal {
    background: linear-gradient(
      180deg,
      var(--color-surface-raised) 0%,
      rgb(0 60 255 / 0.06) 100%
    );
    border-color: rgb(0 60 255 / 0.15);
  }

  .dl-icon {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-md);
    background: rgb(255 255 255 / 0.04);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .dl-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.5rem;
  }

  .dl-body {
    flex: 1;
    margin-bottom: 1rem;
  }

  .dl-card h3 {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.375rem;
  }

  .dl-card p {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.45;
    margin: 0;
  }

  .dl-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .dl-badge {
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .dl-badge.download {
    background: rgb(0 255 174 / 0.15);
    color: var(--color-accent-neon);
    border: 1px solid rgb(0 255 174 / 0.25);
  }

  .dl-badge.portal {
    background: rgb(0 60 255 / 0.15);
    color: var(--color-brand-light);
    border: 1px solid rgb(0 60 255 / 0.3);
  }

  .dl-size {
    font-size: 0.72rem;
    color: var(--color-text-subtle);
    font-variant-numeric: tabular-nums;
  }

  .downloads-note {
    margin-top: 3rem;
    padding: 1.5rem;
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    text-align: center;
  }

  .downloads-note code {
    background: rgb(0 198 231 / 0.1);
    color: var(--color-accent-cyan);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
    font-size: 0.85em;
  }
</style>

<script>
  const fadeEls = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          observer.unobserve(e.target);
        }
      }
    },
    { threshold: 0.05, rootMargin: '0px 0px -40px 0px' },
  );
  for (const el of fadeEls) observer.observe(el);
</script>
