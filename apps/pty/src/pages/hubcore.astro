---
import BaseLayout from '../layouts/BaseLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');

interface Module {
  icon: string;
  name: string;
  description: string;
}

const modules: readonly Module[] = [
  {
    icon: '👥',
    name: 'Clientes',
    description:
      'Gestiona tu cartera de clientes, historial de transacciones y datos de contacto en un solo lugar.',
  },
  {
    icon: '📋',
    name: 'Cotizaciones',
    description:
      'Crea cotizaciones profesionales en segundos y conviértelas en facturas con un clic.',
  },
  {
    icon: '🧾',
    name: 'Facturación',
    description:
      'Emisión de facturas con soporte para factura electrónica (Digifact, The Factory HKA, Factura Fácil).',
  },
  {
    icon: '💰',
    name: 'Cuentas por Cobrar',
    description:
      'Controla saldos pendientes, historial de pagos y alertas de vencimiento por cliente.',
  },
  {
    icon: '📦',
    name: 'Inventario',
    description: 'Administra productos y categorías con control de stock en tiempo real.',
  },
  {
    icon: '🔧',
    name: 'Servicios',
    description: 'Catálogo de servicios reutilizable para agilizar cotizaciones y facturas.',
  },
  {
    icon: '👤',
    name: 'Personal',
    description: 'Gestión de empleados, roles y accesos dentro del sistema.',
  },
  {
    icon: '📊',
    name: 'Reportes',
    description:
      'Gráficas de ingresos, ventas por período, top clientes y análisis financiero en tiempo real.',
  },
  {
    icon: '⚙️',
    name: 'Configuraciones',
    description:
      'Personaliza zona horaria, integración PAC, datos de empresa y preferencias del sistema.',
  },
];

interface ForWhom {
  icon: string;
  title: string;
  description: string;
}

const forWhom: readonly ForWhom[] = [
  {
    icon: '🏪',
    title: 'PYMEs y comercios',
    description:
      'Negocios que necesitan controlar ventas, inventario y clientes sin la complejidad de un ERP tradicional.',
  },
  {
    icon: '🔩',
    title: 'Empresas de servicios',
    description:
      'Talleres, empresas técnicas y consultoras que facturan por servicio y requieren seguimiento de trabajos.',
  },
  {
    icon: '🏢',
    title: 'Distribuidoras',
    description:
      'Negocios con catálogo de productos que necesitan controlar stock, precios y cuentas por cobrar.',
  },
];

const highlights = [
  { value: '9', label: 'Módulos integrados' },
  { value: '3', label: 'Proveedores de factura electrónica' },
  { value: '24/7', label: 'Acceso desde cualquier dispositivo' },
  { value: '100%', label: 'Desarrollado por PROOQ S.A.' },
];

const ctaSubject = encodeURIComponent('Solicito demo de Hub Core');
const ctaBody = encodeURIComponent(
  'Hola, me gustaría agendar una demo de Hub Core para mi empresa.',
);
const mailtoUrl = `mailto:info@prooq.com?subject=${ctaSubject}&body=${ctaBody}`;
const whatsappUrl = `https://wa.me/50762082617?text=${encodeURIComponent('Hola, quiero información sobre Hub Core')}`;
---

<BaseLayout
  title="Hub Core — Sistema de Gestión Empresarial | PROOQ"
  description="Hub Core es el sistema administrativo de PROOQ S.A. para PYMEs: facturación, clientes, inventario, reportes y mucho más, sin complicaciones."
>
  <section class="hc-hero">
    <div class="section-container">
      <img
        src={`${BASE}images/hubcorelogo3.png`}
        alt="Hub Core"
        class="hc-hero-logo fade-in"
        loading="eager"
      />
      <h1 class="hc-hero-tagline fade-in">
        Gestión empresarial<br />
        <span>todo en un solo lugar</span>
      </h1>
      <p class="hc-hero-sub fade-in">
        Hub Core es el sistema administrativo de PROOQ S.A. para PYMEs: facturación, clientes,
        inventario, reportes y mucho más, sin complicaciones.
      </p>
      <div class="hc-hero-btns fade-in">
        <a href={mailtoUrl} class="btn-primary">
          Solicitar demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#modulos" class="btn-secondary">Ver módulos ↓</a>
      </div>
    </div>

    <div class="hc-screenshot fade-in">
      <div class="hc-screenshot-glow" aria-hidden="true"></div>
      <img
        src={`${BASE}images/hubcore.png`}
        alt="Hub Core — Vista del sistema"
        class="hc-screenshot-img"
        loading="lazy"
      />
    </div>
  </section>

  <section class="section section-services hc-what">
    <div class="section-container hc-what-inner">
      <div class="section-label fade-in">¿Qué es Hub Core?</div>
      <h2 class="section-title fade-in">Una plataforma, todas las herramientas</h2>
      <p class="hc-what-body fade-in">
        Hub Core es el sistema de gestión empresarial desarrollado por <strong>PROOQ S.A.</strong>
        para que las empresas panameñas puedan administrar sus operaciones de manera eficiente
        y centralizada. Desde la primera cotización hasta el cobro final, todo el flujo de tu
        negocio en un solo panel, accesible desde cualquier dispositivo.
      </p>
    </div>
  </section>

  <section id="modulos" class="section section-about">
    <div class="section-container">
      <div class="benefits-header fade-in">
        <div class="section-label">Funcionalidades</div>
        <h2 class="section-title">Módulos incluidos</h2>
      </div>

      <div class="modules-grid">
        {modules.map((m) => (
          <article class="module-card fade-in">
            <div class="module-icon" aria-hidden="true">{m.icon}</div>
            <h3 class="module-name">{m.name}</h3>
            <p class="module-desc">{m.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-services hc-forwhom">
    <div class="section-container">
      <div class="benefits-header fade-in">
        <div class="section-label">Perfil de cliente</div>
        <h2 class="section-title">¿Para quién es Hub Core?</h2>
      </div>

      <div class="forwhom-grid">
        {forWhom.map((f) => (
          <article class="forwhom-card fade-in">
            <div class="forwhom-icon" aria-hidden="true">{f.icon}</div>
            <h3 class="forwhom-title">{f.title}</h3>
            <p class="forwhom-desc">{f.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-about hc-highlights">
    <div class="section-container">
      <div class="benefits-header fade-in">
        <div class="section-label">Por qué elegir Hub Core</div>
        <h2 class="section-title">Diseñado para empresas panameñas</h2>
      </div>

      <div class="highlights-grid">
        {highlights.map((h) => (
          <div class="highlight-item fade-in">
            <span class="highlight-num">{h.value}</span>
            <span class="highlight-label">{h.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-portfolio hc-cta">
    <div class="section-container">
      <div class="hc-cta-box fade-in">
        <h2 class="section-title">¿Listo para gestionar tu empresa mejor?</h2>
        <p class="section-subtitle">
          Contáctanos y te mostramos Hub Core en acción. Sin compromisos, sin costos ocultos.
        </p>
        <div class="hc-cta-actions">
          <a href={mailtoUrl} class="btn-primary">
            Solicitar información por email
          </a>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">
            💬 Escribir por WhatsApp
          </a>
        </div>
        <p class="hc-back">
          <a href={`${BASE}servicios`}>← Volver a Servicios</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hc-hero {
    padding: 8rem 0 0;
    text-align: center;
    background: radial-gradient(
      ellipse at top,
      rgb(0 60 255 / 0.18) 0%,
      var(--color-surface) 55%
    );
    overflow: hidden;
  }

  .hc-hero-logo {
    max-width: 280px;
    height: auto;
    margin: 0 auto 2rem;
    filter: drop-shadow(0 8px 32px rgb(0 212 255 / 0.3));
  }

  .hc-hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    line-height: 1.15;
    letter-spacing: 0.02em;
  }

  .hc-hero-tagline span {
    background: linear-gradient(45deg, var(--color-brand-light), var(--color-accent-cyan));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hc-hero-sub {
    color: var(--color-text-soft);
    font-size: 1.15rem;
    line-height: 1.6;
    max-width: 720px;
    margin: 0 auto 2rem;
  }

  .hc-hero-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }

  .btn-primary {
    background: linear-gradient(45deg, var(--color-brand), var(--color-brand-light));
    color: var(--color-text);
    box-shadow: var(--shadow-cta);
    border: none;
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-cta-hover);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 2px solid rgb(255 255 255 / 0.2);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    border-color: var(--color-brand-light);
    color: var(--color-brand-light);
  }

  /* Screenshot */
  .hc-screenshot {
    max-width: 1100px;
    margin: 1rem auto 0;
    position: relative;
    padding: 0 1rem;
  }

  .hc-screenshot-glow {
    position: absolute;
    inset: -20% 0 0 0;
    background: radial-gradient(ellipse at center top, rgb(0 198 231 / 0.25) 0%, transparent 60%);
    z-index: 0;
    pointer-events: none;
  }

  .hc-screenshot-img {
    position: relative;
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid rgb(255 255 255 / 0.08);
    box-shadow: 0 32px 80px rgb(0 0 0 / 0.5);
    z-index: 1;
  }

  /* "Qué es" */
  .hc-what-inner {
    max-width: 760px;
    text-align: center;
  }

  .hc-what-body {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 1rem 0 0;
  }

  .hc-what-body strong {
    color: var(--color-text);
  }

  /* Sections shared */
  .benefits-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    display: inline-block;
    color: var(--color-accent-cyan);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  /* Modules grid */
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .module-card {
    background: var(--color-surface);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .module-card:hover {
    transform: translateY(-3px);
    border-color: rgb(0 198 231 / 0.4);
  }

  .module-icon {
    font-size: 2rem;
    margin-bottom: 0.625rem;
  }

  .module-name {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.1rem;
    margin: 0 0 0.375rem;
  }

  .module-desc {
    color: var(--color-text-secondary);
    line-height: 1.55;
    font-size: 0.92rem;
    margin: 0;
  }

  /* For whom */
  .forwhom-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .forwhom-card {
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-lg);
    padding: 2rem 1.5rem;
    text-align: center;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .forwhom-card:hover {
    transform: translateY(-3px);
    border-color: rgb(0 198 231 / 0.4);
  }

  .forwhom-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .forwhom-title {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
  }

  .forwhom-desc {
    color: var(--color-text-secondary);
    line-height: 1.55;
    font-size: 0.92rem;
    margin: 0;
  }

  /* Highlights */
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .highlight-item {
    text-align: center;
    padding: 1.5rem 0.75rem;
    background: var(--color-surface);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-md);
  }

  .highlight-num {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(45deg, #ffffff, var(--color-brand-light));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    margin-bottom: 0.25rem;
  }

  .highlight-label {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* CTA */
  .hc-cta-box {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: linear-gradient(
      135deg,
      var(--color-surface-raised) 0%,
      rgb(0 60 255 / 0.1) 100%
    );
    border: 1px solid rgb(0 198 231 / 0.2);
    border-radius: var(--radius-lg);
    box-shadow: 0 16px 48px rgb(0 0 0 / 0.4);
  }

  .hc-cta-actions {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hc-back {
    margin: 2rem 0 0;
    font-size: 0.9rem;
  }

  .hc-back a {
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .hc-back a:hover {
    color: var(--color-brand-light);
  }

  /* Hero gradient title */
  .section-title span {
    background: linear-gradient(45deg, var(--color-brand-light), var(--color-accent-cyan));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  @media (max-width: 700px) {
    .hc-hero { padding: 6rem 0 0; }
    .hc-hero-logo { max-width: 200px; }
    .highlights-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  const fadeEls = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          observer.unobserve(e.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
  );
  for (const el of fadeEls) observer.observe(el);
</script>
