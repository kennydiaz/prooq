---
import { getCollection } from 'astro:content';
import { BlogList } from '@prooq/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    description: p.data.description,
    pubDate: p.data.pubDate,
    tags: p.data.tags,
  }));
---

<BaseLayout
  title="Blog | PROOQ S.A. — Tecnología y automatización para PYMEs en Panamá"
  description="Artículos prácticos sobre automatización, seguridad electrónica, desarrollo web y tecnología para negocios en Panamá."
>
  <BlogList posts={posts} locale="es-PA" />
</BaseLayout>
