---
import { getTeam } from '@prooq/data-client/team';
import { ChatFab, HeroParallax, Starfield } from '@prooq/ui';
import BaseLayout from '../layouts/BaseLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const services = [
  {
    icon: '🤖',
    title: 'Agentes Inteligentes con n8n',
    description: 'Automatización avanzada y agentes inteligentes para empresas.',
    features: ['Workflows N8N', 'Chatbots IA', 'Integraciones API', 'Procesos automatizados'],
  },
  {
    icon: '📹',
    title: 'Seguridad Electrónica',
    description: 'Soluciones avanzadas de videovigilancia y control de acceso para tu negocio.',
    features: [
      'CCTV / Videovigilancia',
      'Control de acceso',
      'Alarmas inteligentes',
      'Monitoreo 24/7',
    ],
  },
  {
    icon: '🌐',
    title: 'Desarrollo Web',
    description: 'Soluciones web profesionales para empresas y negocios.',
    features: ['Landing pages', 'Sitios corporativos', 'E-commerce', 'Aplicaciones web'],
  },
  {
    icon: '🔒',
    title: 'Ciberseguridad y Protección de Datos',
    description: 'Control de accesos, encriptación y monitoreo continuo para tu empresa.',
    features: [
      'Threat detection',
      'Encriptación at rest',
      'Políticas de acceso',
      'Auditorías de cumplimiento',
    ],
  },
  {
    icon: '🔌',
    title: 'Redes Cableadas e Infraestructura',
    description: 'Diseño y administración de redes locales, remotas y en la nube.',
    features: [
      'Cableado Cat6/Cat7',
      'Switches y routers',
      'Redes locales / cloud',
      'VPN y acceso remoto',
    ],
  },
  {
    icon: '🧑‍💻',
    title: 'Sistemas Administrativos',
    description: 'Software a medida para optimizar la gestión de tu empresa.',
    features: ['Integración ERP', 'Dashboards', 'Automatización de procesos', 'Analítica de datos'],
  },
  {
    icon: '🛠️',
    title: 'Automatización y Control Inteligente',
    description: 'Soluciones para automatizar procesos, edificios y sistemas de seguridad.',
    features: [
      'Automatización de edificios',
      'IoT',
      'Sensores inteligentes',
      'Control de procesos',
    ],
  },
  {
    icon: '💡',
    title: 'Consultoría Tecnológica',
    description: 'Asesoramos a empresas en la adopción eficiente de tecnología.',
    features: [
      'Transformación digital',
      'Auditorías técnicas',
      'Selección de proveedores',
      'Roadmaps tecnológicos',
    ],
  },
];

const stats = [
  { value: '25+', label: 'Años de experiencia' },
  { value: '200+', label: 'Clientes en Panamá' },
  { value: '15+', label: 'Profesionales' },
];

// Equipo desde el CMS (build-time) con fallback hardcodeado si la API falla.
const fallbackTeam = [
  { name: 'Kenny', role: 'Especialista en Redes', photo: `${BASE}images/team/kenny.jpg` },
  { name: 'Fernando', role: 'Experto en Seguridad', photo: `${BASE}images/team/fernando.jpg` },
  { name: 'Angelo', role: 'Desarrollo de Sistemas', photo: `${BASE}images/team/angelo.jpg` },
  { name: 'Daniel', role: 'Soporte Técnico', photo: `${BASE}images/team/daniel.jpg` },
  { name: 'Irwin', role: 'Infraestructura', photo: `${BASE}images/team/irwin.jpg` },
  { name: 'Lázaro', role: 'Coordinador de Proyectos', photo: `${BASE}images/team/lazaro.jpg` },
];
const initials = (name: string): string =>
  name
    .split(/\s+/)
    .map((p) => p[0] ?? '')
    .slice(0, 2)
    .join('')
    .toUpperCase();
let team: { name: string; role: string; photo: string }[] = fallbackTeam;
try {
  const fetched = await getTeam('PA');
  if (fetched.length > 0) {
    team = fetched.map((m) => ({ name: m.name, role: m.role ?? '', photo: m.photoUrl ?? '' }));
  }
} catch (err) {
  console.warn('[team] getTeam failed, usando fallback:', err);
}

const portfolio = [
  {
    name: 'aerovisionstudio.com',
    description: 'Servicios de drones, fotografía aérea y producción audiovisual.',
    url: 'https://aerovisionstudio.com',
  },
  {
    name: 'prooq.com',
    description: 'Soluciones tecnológicas, seguridad electrónica, infraestructura y sistemas.',
    url: 'https://prooq.com',
  },
  {
    name: 'bgselectrician.com',
    description: 'Manpower & Staffing para contratistas eléctricos.',
    url: 'https://bgselectrician.com',
  },
  {
    name: 'mansionperruna.com',
    description: 'Hotel canino, guardería y servicios premium para mascotas.',
    url: 'https://mansionperruna.com',
  },
  {
    name: 'vieniqua.com',
    description: 'Restaurante de comida italiana.',
    url: 'https://vieniqua.com',
  },
  {
    name: 'cleanfactorypty.com',
    description: 'Servicios profesionales de limpieza de zapatillas.',
    url: 'https://cleanfactorypty.com',
  },
  {
    name: 'varasgrillandbar.com',
    description: 'Restaurante, bar y parrilla con menú y reservas digitales.',
    url: 'https://varasgrillandbar.com',
  },
  {
    name: 'makanolake.com',
    description: 'Cabañas agroturísticas junto al Lago San Carlos.',
    url: 'https://makanolake.com',
  },
  {
    name: 'tallerqsexpress.com',
    description: 'Taller automotriz, mecánica rápida y diagnósticos.',
    url: 'https://tallerqsexpress.com',
  },
  {
    name: 'bootsgloves.com',
    description:
      'Servicios profesionales de demolición, retiro de escombros y limpieza en Atlanta, Georgia.',
    url: 'https://bootsgloves.com',
  },
  {
    name: 'dastvnetwork.com',
    description: 'Tecnología de marketing y publicidad digital.',
    url: 'https://dastvnetwork.com',
  },
  {
    name: 'bgs50.com',
    description: 'Plataforma de servicios y soluciones para la industria.',
    url: 'https://bgs50.com',
  },
] as const;

const locationDetails = [
  { icon: '📍', title: 'Sede Principal', text: 'Ciudad de Panamá, Panamá' },
  { icon: '🌎', title: 'Cobertura', text: 'Panamá y Centroamérica' },
  { icon: '⏰', title: 'Horario', text: 'Lun - Vie: 8:00 - 17:00' },
];
---

<BaseLayout
  title="PROOQ S.A. — Soluciones Tecnológicas en Panamá"
  description="PROOQ Panamá: SuiteHub, seguridad electrónica, redes, automatización con IA y chat. Sede principal en Ciudad de Panamá."
>
  <Starfield />

  <HeroParallax
    title="PROOQ"
    subtitle="Soluciones tecnológicas integrales para empresas"
    description="Especialistas en cableado estructurado, seguridad electrónica y automatización empresarial en Panamá"
    cta={{ label: 'Conoce SuiteHub', href: '#suitehub' }}
  >
    <div class="hero-extras">
      <a href="#contact" class="cta-secondary">Contáctanos</a>
      <p class="hero-location">📍 Ciudad de Panamá, Panamá 🇵🇦</p>
    </div>
  </HeroParallax>

  <section id="suitehub" class="section section-services suitehub-feature">
    <div class="section-container">
      <div class="suitehub-grid">
        <div class="suitehub-content fade-in">
          <div class="suitehub-eyebrow">⚡ Producto propio · PA · US · VE · ES</div>
          <h2 class="section-title">
            <span class="brand-name">SuiteHub</span><br />
            <span>Suite empresarial que sí escala</span>
          </h2>
          <p class="suitehub-lead">
            Plataforma de gestión para PYMEs con facturación electrónica multi-jurisdicción,
            multi-sucursal, automatizaciones y API REST. 4 ediciones desde <strong>$19/mes</strong>.
          </p>
          <ul class="suitehub-features">
            <li>✓ Facturación electrónica DGI Panamá (en vivo)</li>
            <li>✓ 12 verticales especializadas (HUB Taller, Restaurant, POS, Pet, Beauty, Clinic, Gym, Hotel, +5)</li>
            <li>✓ WhatsApp Business + automatizaciones</li>
            <li>✓ Disponible en español e inglés</li>
          </ul>
          <div class="suitehub-actions">
            <a href="https://suitehub.net/" target="_blank" rel="noopener" class="suitehub-cta-primary">
              Conocer SuiteHub →
            </a>
            <a
              href="https://wa.me/50762082617?text=Hola%2C%20quiero%20info%20de%20SuiteHub"
              target="_blank"
              rel="noopener noreferrer"
              class="suitehub-cta-secondary"
            >
              💬 Hablar con ventas
            </a>
          </div>
        </div>
        <div class="suitehub-stats fade-in">
          <div class="suitehub-stat"><span class="stat-num">$19</span><span class="stat-lbl">desde / mes</span></div>
          <div class="suitehub-stat"><span class="stat-num">4</span><span class="stat-lbl">países objetivo</span></div>
          <div class="suitehub-stat"><span class="stat-num">12</span><span class="stat-lbl">verticales HUB</span></div>
          <div class="suitehub-stat"><span class="stat-num">+30</span><span class="stat-lbl">PYMEs en producción</span></div>
        </div>
      </div>
    </div>
  </section>

  <section id="servicios" class="section section-services">
    <div class="section-container">
      <h2 class="section-title fade-in">Servicios técnicos complementarios</h2>
      <p class="section-subtitle fade-in">
        Además de SuiteHub ofrecemos servicios de infraestructura, seguridad, automatización y consultoría para empresas en Panamá.
      </p>
      <div class="services-grid">
        {services.map((s) => (
          <article class="service-card fade-in">
            <div class="service-icon" aria-hidden="true">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <ul>
              {s.features.map((f) => <li>{f}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-about">
    <div class="section-container">
      <div class="about-grid">
        <div class="fade-in">
          <h2 class="section-title">Sobre PROOQ S.A.</h2>
          <p>
            PROOQ S.A. es la sede principal del grupo, con base en Ciudad de Panamá. Desde aquí
            coordinamos las operaciones regionales y desarrollamos <strong>SuiteHub</strong>,
            nuestra plataforma SaaS multi-jurisdicción para PYMEs en Panamá, USA, Venezuela y España.
          </p>
          <p>
            Combinamos infraestructura técnica (cableado estructurado, seguridad electrónica,
            redes) con software a medida y consultoría para empresas que necesitan modernizar
            sus operaciones.
          </p>
          <div class="stats">
            {stats.map((s) => (
              <div class="stat">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="equipo" class="section section-team">
    <div class="section-container">
      <h2 class="section-title fade-in">Nuestro Equipo</h2>
      <p class="section-subtitle fade-in">Los profesionales detrás de cada proyecto PROOQ</p>
      <div class="team-grid">
        {team.map((m) => (
          <article class="team-member fade-in">
            {m.photo ? (
              <img src={m.photo} alt={m.name} loading="lazy" />
            ) : (
              <span class="team-avatar-fallback" aria-hidden="true">{initials(m.name)}</span>
            )}
            <h3>{m.name}</h3>
            <p>{m.role}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="portafolio" class="section section-portfolio">
    <div class="section-container">
      <h2 class="section-title fade-in">Portafolio Web</h2>
      <p class="section-subtitle fade-in">
        Una selección de sitios diseñados y desarrollados por nuestro equipo. Cada proyecto
        refleja nuestro compromiso con la calidad, la innovación y la excelencia técnica.
      </p>
      <div class="portfolio-grid">
        {portfolio.map((p) => (
          <article class="portfolio-card fade-in">
            <h3>{p.name}</h3>
            <p>{p.description}</p>
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="portfolio-link">
              Visitar sitio →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="ubicacion" class="section section-location">
    <div class="section-container">
      <div class="location-grid">
        <div class="fade-in">
          <h2 class="section-title">Ubicados en Ciudad de Panamá</h2>
          <p>
            Sede principal del grupo PROOQ. Atendemos clientes en todo Panamá y la región
            centroamericana con soluciones tecnológicas integrales.
          </p>
          <div class="location-details">
            {locationDetails.map((d) => (
              <div class="location-detail">
                <span class="detail-icon" aria-hidden="true">{d.icon}</span>
                <div>
                  <h4>{d.title}</h4>
                  <p>{d.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <ChatFab country="pty" />
</BaseLayout>

<style>
  /* SuiteHub feature section — destacada, mas grande que las demás */
  .suitehub-feature {
    background: radial-gradient(
      ellipse at center top,
      rgb(0 60 255 / 0.22) 0%,
      rgb(5 13 31 / 0.55) 60%
    );
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding-top: 6rem;
    padding-bottom: 5rem;
  }

  .suitehub-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .suitehub-eyebrow {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgb(0 198 231 / 0.1);
    border: 1px solid rgb(0 198 231 / 0.3);
    color: var(--color-accent-cyan);
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
  }

  .brand-name {
    font-size: 3rem;
    line-height: 1;
    background: linear-gradient(45deg, var(--color-brand-light), var(--color-accent-cyan));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    display: inline-block;
  }

  .suitehub-content .section-title {
    margin-bottom: 1rem;
  }

  .suitehub-lead {
    color: var(--color-text-soft);
    font-size: 1.1rem;
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }

  .suitehub-lead strong {
    color: var(--color-accent-cyan);
  }

  .suitehub-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .suitehub-features li {
    color: var(--color-text-soft);
    line-height: 1.55;
    font-size: 0.95rem;
  }

  .suitehub-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .suitehub-cta-primary,
  .suitehub-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }

  .suitehub-cta-primary {
    background: linear-gradient(45deg, var(--color-brand), var(--color-brand-light));
    color: var(--color-text);
    box-shadow: var(--shadow-cta);
  }

  .suitehub-cta-primary:hover,
  .suitehub-cta-primary:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-cta-hover);
  }

  .suitehub-cta-secondary {
    background: transparent;
    color: var(--color-text);
    border: 2px solid rgb(255 255 255 / 0.2);
  }

  .suitehub-cta-secondary:hover,
  .suitehub-cta-secondary:focus-visible {
    border-color: var(--color-brand-light);
    color: var(--color-brand-light);
  }

  .suitehub-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .suitehub-stat {
    background: var(--color-surface-raised);
    border: 1px solid rgb(0 198 231 / 0.15);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1rem;
    text-align: center;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .suitehub-stat:hover {
    border-color: rgb(0 198 231 / 0.4);
    transform: translateY(-2px);
  }

  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    background: linear-gradient(45deg, #ffffff, var(--color-brand-light));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    margin-bottom: 0.125rem;
  }

  .stat-lbl {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (max-width: 900px) {
    .suitehub-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .brand-name { font-size: 2.4rem; }
  }
</style>

<!-- Secciones semi-transparentes para que el cielo estelar (Starfield) se vea detrás.
     Scoped solo a esta página vía is:global; las tarjetas internas siguen opacas. -->
<style is:global>
  main .section-services,
  main .section-team {
    background: rgb(5 13 31 / 0.62);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  main .section-about,
  main .section-portfolio {
    background: rgb(10 24 51 / 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  main .section-location {
    background: rgb(5 13 31 / 0.62);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
</style>

<script>
  // Fade-in al scroll — IntersectionObserver replicado del V1.
  const elements = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' },
  );

  for (const el of elements) observer.observe(el);
</script>
