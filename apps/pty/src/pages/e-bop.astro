---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Benefit {
  icon: string;
  number: string;
  title: string;
  description: string;
  tags: readonly string[];
}

const benefits: readonly Benefit[] = [
  {
    icon: '🔍',
    number: '01',
    title: 'Visibilidad total del proyecto',
    description:
      'Ve en tiempo real todo lo que ocurre en obra: personal, materiales y avance. Elimina el desorden y mejora el control general.',
    tags: ['Tiempo real', 'Control central'],
  },
  {
    icon: '⏱️',
    number: '02',
    title: 'Control del trabajo en campo',
    description:
      'Monitorea horas trabajadas, check-in del personal y actividad en obra. Mejora la productividad y reduce pérdidas de tiempo.',
    tags: ['Check-in', 'Horas trabajadas'],
  },
  {
    icon: '📦',
    number: '03',
    title: 'Gestión inteligente de materiales',
    description:
      'Inventario en tiempo real, seguimiento de uso y entregas. Menos desperdicio, menos fugas de dinero en materiales.',
    tags: ['Inventario', 'Seguimiento', 'Entregas'],
  },
  {
    icon: '📅',
    number: '04',
    title: 'Control del cronograma',
    description:
      'Seguimiento de hitos, alertas de retraso y control dinámico del timeline. Anticípate a los problemas antes de que impacten el proyecto.',
    tags: ['Hitos', 'Alertas', 'Timeline'],
  },
  {
    icon: '📊',
    number: '05',
    title: 'Reportes para toma de decisiones',
    description:
      'Genera reportes con rendimiento del equipo, uso de recursos y avance real vs plan. Decisiones basadas en datos, no en intuición.',
    tags: ['Rendimiento', 'Recursos', 'Avance'],
  },
  {
    icon: '🔗',
    number: '06',
    title: 'Integración campo ↔ oficina',
    description:
      'Conecta el equipo en campo con el personal administrativo. Todo en una sola plataforma en la nube, sin descoordinación.',
    tags: ['Nube', 'Sincronizado'],
  },
  {
    icon: '💬',
    number: '07',
    title: 'Comunicación directa y eficiente',
    description:
      'Mensajería interna y actualizaciones en tiempo real. Reduce errores causados por mala comunicación entre equipos.',
    tags: ['Mensajería', 'Actualizaciones'],
  },
  {
    icon: '📱',
    number: '08',
    title: 'Acceso desde cualquier lugar',
    description:
      'Disponible en móvil y escritorio. Supervisa tus proyectos sin necesidad de estar físicamente en sitio.',
    tags: ['Móvil', 'Escritorio', 'Multiplataforma'],
  },
  {
    icon: '🚀',
    number: '09',
    title: 'Mayor productividad, menos costos',
    description:
      'Al combinar todo lo anterior: reduces retrasos, optimizas recursos y mejoras eficiencia. Más rentabilidad por proyecto.',
    tags: ['Rentabilidad', 'Eficiencia'],
  },
];

const heroStats = [
  { value: '9', label: 'Módulos integrados' },
  { value: '100%', label: 'En la nube' },
  { value: '24/7', label: 'Acceso en tiempo real' },
];
---

<BaseLayout
  title="E-BOP — Gestión de Obra en Tiempo Real | PROOQ"
  description="E-BOP conecta tu equipo en campo con la oficina. Personal, materiales, cronograma y reportes en tiempo real desde cualquier lugar."
>
  <section class="ebop-hero">
    <div class="section-container">
      <div class="hero-badge fade-in">🏗️ Plataforma de gestión de obra</div>
      <h1 class="hero-title fade-in">
        Obra bajo <span>control total</span>
      </h1>
      <p class="hero-sub fade-in">
        E-BOP conecta tu equipo en campo con la oficina. Personal, materiales, cronograma y
        reportes — todo en tiempo real, desde cualquier lugar.
      </p>
      <div class="hero-actions fade-in">
        <a href="#solicitar" class="btn-primary">
          Solicitar demo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#beneficios" class="btn-secondary">Ver beneficios</a>
      </div>
      <div class="hero-stats fade-in">
        {heroStats.map((s) => (
          <div class="hero-stat">
            <span class="hero-stat-value">{s.value}</span>
            <span class="hero-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="beneficios" class="section section-services">
    <div class="section-container">
      <div class="benefits-header fade-in">
        <div class="section-label">Por qué E-BOP</div>
        <h2 class="section-title">
          Todo lo que necesitas para <span>gestionar tu obra</span>
        </h2>
        <p class="section-subtitle">
          De la confusión al control — E-BOP centraliza cada aspecto de tu proyecto en una sola plataforma.
        </p>
      </div>

      <div class="benefits-grid">
        {benefits.map((b) => (
          <article class="benefit-card fade-in">
            <div class="benefit-icon" aria-hidden="true">{b.icon}</div>
            <div class="benefit-number">{b.number}</div>
            <h3 class="benefit-title">{b.title}</h3>
            <p class="benefit-desc">{b.description}</p>
            <div class="benefit-tags">
              {b.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-about ebop-summary">
    <div class="section-container">
      <div class="summary-inner fade-in">
        <div class="section-label">En pocas palabras</div>
        <h2 class="section-title">
          E-BOP te da <span>lo que realmente importa</span>
        </h2>
        <p>
          Olvida las hojas de cálculo, los grupos de WhatsApp y los reportes manuales.
          E-BOP centraliza todo para que puedas enfocarte en construir.
        </p>
        <ul class="summary-list">
          <li>Control total del proyecto en tiempo real</li>
          <li>Menos caos y desorden en obra</li>
          <li>Decisiones respaldadas por datos</li>
          <li>Mayor eficiencia operativa</li>
          <li>Más rentabilidad al cierre del proyecto</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="solicitar" class="section section-portfolio ebop-cta">
    <div class="section-container">
      <div class="cta-inner fade-in">
        <h2 class="section-title">
          ¿Listo para tener tu obra <span>bajo control</span>?
        </h2>
        <p class="section-subtitle">
          Solicita una demo personalizada. Te contactamos en menos de 24 horas para mostrarte
          E-BOP en acción con tu caso real.
        </p>

        <form id="ebop-form" class="ebop-form" novalidate>
          <div class="form-row">
            <div class="form-field">
              <label for="ebop-company">Empresa <span class="req">*</span></label>
              <input
                id="ebop-company"
                name="company_name"
                type="text"
                required
                maxlength="255"
                autocomplete="organization"
                placeholder="Constructora Pérez S.A."
              />
            </div>
            <div class="form-field">
              <label for="ebop-contact">Nombre <span class="req">*</span></label>
              <input
                id="ebop-contact"
                name="contact_name"
                type="text"
                required
                maxlength="255"
                autocomplete="name"
                placeholder="Juan Pérez"
              />
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label for="ebop-email">Email <span class="req">*</span></label>
              <input
                id="ebop-email"
                name="email"
                type="email"
                required
                maxlength="255"
                autocomplete="email"
                placeholder="juan@empresa.com"
              />
            </div>
            <div class="form-field">
              <label for="ebop-phone">Teléfono <span class="opt">(opcional)</span></label>
              <input
                id="ebop-phone"
                name="phone"
                type="tel"
                maxlength="50"
                autocomplete="tel"
                placeholder="+507 6XXX-XXXX"
              />
            </div>
          </div>
          <div class="form-field">
            <label for="ebop-message">Mensaje <span class="opt">(opcional)</span></label>
            <textarea
              id="ebop-message"
              name="message"
              rows="4"
              maxlength="2000"
              placeholder="Cuéntanos brevemente sobre tu proyecto u obra"
            ></textarea>
          </div>
          <button type="submit" class="btn-primary" id="ebop-submit">
            Enviar solicitud
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
          <p id="ebop-result" class="form-result" role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero E-BOP */
  .ebop-hero {
    padding: 8rem 0 4rem;
    background: radial-gradient(
      ellipse at top,
      rgb(0 60 255 / 0.15) 0%,
      var(--color-surface) 50%
    );
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgb(0 198 231 / 0.1);
    border: 1px solid rgb(0 198 231 / 0.3);
    color: var(--color-accent-cyan);
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .hero-title span {
    background: linear-gradient(45deg, var(--color-brand-light), var(--color-accent-cyan));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero-sub {
    color: var(--color-text-soft);
    font-size: 1.15rem;
    line-height: 1.6;
    max-width: 720px;
    margin: 0 auto 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }

  .btn-primary {
    background: linear-gradient(45deg, var(--color-brand), var(--color-brand-light));
    color: var(--color-text);
    box-shadow: var(--shadow-cta);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--shadow-cta-hover);
  }

  .btn-primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 2px solid rgb(255 255 255 / 0.2);
  }

  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    border-color: var(--color-brand-light);
    color: var(--color-brand-light);
  }

  .hero-stats {
    display: flex;
    gap: 3rem;
    justify-content: center;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid rgb(255 255 255 / 0.06);
  }

  .hero-stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(45deg, #ffffff, var(--color-brand-light));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero-stat-label {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Benefits */
  .benefits-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    display: inline-block;
    color: var(--color-accent-cyan);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .section-title span {
    background: linear-gradient(45deg, var(--color-brand-light), var(--color-accent-cyan));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .benefit-card {
    position: relative;
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-lg);
    padding: 2rem 1.5rem 1.5rem;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .benefit-card:hover {
    transform: translateY(-4px);
    border-color: rgb(0 198 231 / 0.4);
  }

  .benefit-icon {
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .benefit-number {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
  }

  .benefit-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .benefit-desc {
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
    margin: 0 0 1rem;
  }

  .benefit-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.25rem 0.625rem;
    background: rgb(0 60 255 / 0.15);
    color: var(--color-brand-light);
    border-radius: var(--radius-pill);
    font-weight: 500;
  }

  /* Summary */
  .summary-inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .summary-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0.75rem;
    text-align: left;
  }

  .summary-list li {
    color: var(--color-text-soft);
    padding: 0.5rem 0 0.5rem 1.5rem;
    position: relative;
  }

  .summary-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent-neon);
    font-weight: 700;
  }

  /* CTA Form */
  .cta-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .ebop-form {
    margin-top: 2.5rem;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-field label {
    color: var(--color-text-soft);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .req { color: var(--color-accent-cyan); }
  .opt {
    color: var(--color-text-muted);
    font-weight: 400;
    font-size: 0.8em;
  }

  .form-field input,
  .form-field textarea {
    background: var(--color-surface);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    padding: 0.75rem 1rem;
    transition: border-color 0.2s ease;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-accent-cyan);
  }

  .form-field input:invalid:not(:placeholder-shown) {
    border-color: rgb(255 80 80 / 0.6);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 96px;
  }

  #ebop-submit {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .form-result {
    margin: 0.5rem 0 0;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.95rem;
    display: none;
  }

  .form-result.is-success {
    display: block;
    background: rgb(0 255 174 / 0.1);
    border: 1px solid rgb(0 255 174 / 0.3);
    color: var(--color-accent-neon);
  }

  .form-result.is-error {
    display: block;
    background: rgb(255 80 80 / 0.1);
    border: 1px solid rgb(255 80 80 / 0.3);
    color: #ffb3b3;
  }

  @media (max-width: 700px) {
    .ebop-hero { padding: 6rem 0 3rem; }
    .form-row { grid-template-columns: 1fr; }
    .hero-stats { gap: 1.5rem; }
    .hero-stat-value { font-size: 2rem; }
  }
</style>

<script>
  import { submitEbopRequest } from '@prooq/data-client/ebop';

  // Fade-in scroll observer
  const fadeEls = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          observer.unobserve(e.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
  );
  for (const el of fadeEls) observer.observe(el);

  // Form submit
  const form = document.getElementById('ebop-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('ebop-submit') as HTMLButtonElement | null;
  const result = document.getElementById('ebop-result') as HTMLParagraphElement | null;

  const setResult = (kind: 'success' | 'error', msg: string) => {
    if (!result) return;
    result.classList.remove('is-success', 'is-error');
    result.classList.add(`is-${kind}`);
    result.textContent = msg;
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    const payload = {
      company_name: String(data.get('company_name') ?? '').trim(),
      contact_name: String(data.get('contact_name') ?? '').trim(),
      email: String(data.get('email') ?? '').trim(),
      phone: String(data.get('phone') ?? '').trim() || undefined,
      message: String(data.get('message') ?? '').trim() || undefined,
    };

    if (submitBtn) submitBtn.disabled = true;
    if (result) result.classList.remove('is-success', 'is-error');

    try {
      const res = await submitEbopRequest(payload);
      if (res.ok) {
        setResult(
          'success',
          '✓ Solicitud enviada. Te contactamos en menos de 24 horas al email que indicaste.',
        );
        form.reset();
      } else {
        setResult(
          'error',
          `No pudimos guardar tu solicitud (${res.error}). Escríbenos a info@prooq.com o WhatsApp +507 6208-2617.`,
        );
      }
    } catch (err) {
      console.error('[e-bop] submit failed:', err);
      setResult(
        'error',
        'Error de conexión. Escríbenos a info@prooq.com o WhatsApp +507 6208-2617 y te respondemos hoy mismo.',
      );
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
