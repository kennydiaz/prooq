---
import { HeroParallax } from '@prooq/ui';
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    icon: '💻',
    title: 'Desarrollo Web',
    description:
      'Sitios web modernos, responsivos y optimizados. Desde landing pages hasta aplicaciones web complejas con las últimas tecnologías.',
    features: [
      'Diseño responsive y moderno',
      'Optimización SEO',
      'E-commerce y tiendas online',
      'Aplicaciones web personalizadas',
    ],
  },
  {
    icon: '🤖',
    title: 'Agentes Inteligentes',
    description:
      'Chatbots e IA conversacional para automatizar la atención al cliente y mejorar la experiencia de usuario las 24/7.',
    features: [
      'Chatbots inteligentes',
      'Asistentes virtuales',
      'Automatización de procesos',
      'Integración con sistemas existentes',
    ],
  },
  {
    icon: '📱',
    title: 'Consultoría Digital',
    description:
      'Asesoramiento especializado en transformación digital para empresas locales en Cádiz y toda Andalucía.',
    features: [
      'Estrategia digital',
      'Análisis de procesos',
      'Implementación tecnológica',
      'Formación y soporte',
    ],
  },
];

const stats = [
  { value: '50+', label: 'Proyectos Completados' },
  { value: '100%', label: 'Clientes Satisfechos' },
  { value: '15+', label: 'Soporte Técnico' },
];

const team = [
  {
    name: 'Victor Tineo',
    role: 'Lead Developer & Co-Fundador',
    photo: '/images/victor.jpg',
    bio: 'Victor lidera nuestro equipo de desarrollo, especializado en crear experiencias digitales excepcionales y en la implementación de soluciones de IA conversacional.',
    skills: ['React', 'Node.js', 'Python', 'AI/ML', 'ChatGPT API'],
    expertise:
      'Su experiencia en tecnologías modernas y su enfoque en la innovación garantizan que cada proyecto incorpore las mejores prácticas del desarrollo web actual.',
  },
];

const portfolio = [
  {
    name: 'aerovisionstudio.com',
    description: 'Servicios de drones, fotografía aérea y producción audiovisual.',
    url: 'https://aerovisionstudio.com',
  },
  {
    name: 'prooq.com',
    description: 'Soluciones tecnológicas, seguridad electrónica, infraestructura y sistemas.',
    url: 'https://prooq.com',
  },
  {
    name: 'bgselectrician.com',
    description: 'Manpower & Staffing para contratistas eléctricos.',
    url: 'https://bgselectrician.com',
  },
  {
    name: 'mansionperruna.com',
    description: 'Hotel canino, guardería y servicios premium para mascotas.',
    url: 'https://mansionperruna.com',
  },
  {
    name: 'vieniqua.com',
    description: 'Restaurante de comida italiana.',
    url: 'https://vieniqua.com',
  },
  {
    name: 'cleanfactorypty.com',
    description: 'Servicios profesionales de limpieza de zapatillas.',
    url: 'https://cleanfactorypty.com',
  },
  {
    name: 'varasgrillandbar.com',
    description: 'Restaurante, bar y parrilla con menú y reservas digitales.',
    url: 'https://varasgrillandbar.com',
  },
  {
    name: 'makanolake.com',
    description: 'Cabañas agroturísticas junto al Lago San Carlos.',
    url: 'https://makanolake.com',
  },
  {
    name: 'tallerqsexpress.com',
    description: 'Taller automotriz, mecánica rápida y diagnósticos.',
    url: 'https://tallerqsexpress.com',
  },
  {
    name: 'bootsgloves.com',
    description:
      'Servicios profesionales de demolición, retiro de escombros y limpieza en Atlanta, Georgia.',
    url: 'https://bootsgloves.com',
  },
  {
    name: 'dastvnetwork.com',
    description: 'Tecnología de marketing y publicidad digital.',
    url: 'https://dastvnetwork.com',
  },
  {
    name: 'bgs50.com',
    description: 'Plataforma de servicios y soluciones para la industria.',
    url: 'https://bgs50.com',
  },
] as const;

const locationDetails = [
  { icon: '📍', title: 'Sede Principal', text: 'Cádiz, Andalucía' },
  { icon: '🌍', title: 'Cobertura', text: 'España y Europa' },
  { icon: '⏰', title: 'Horario', text: 'Lun - Vie: 9:00 - 18:00' },
];
---

<BaseLayout
  title="PROOQ España — Desarrollo Web y Agentes Inteligentes | Cádiz"
  description="Especialistas en desarrollo web y agentes inteligentes para empresas en Cádiz y Andalucía. Soluciones tecnológicas innovadoras."
>
  <HeroParallax
    title="PROOQ España"
    subtitle="Desarrollo Web & Agentes Inteligentes"
    description="Transformamos tu negocio con soluciones tecnológicas avanzadas desde Cádiz para toda España"
    cta={{ label: 'Nuestros Servicios', href: '#servicios' }}
  >
    <div class="hero-extras">
      <a href="#contacto" class="cta-secondary">Contáctanos</a>
      <p class="hero-location">📍 Cádiz, Andalucía — España 🇪🇸</p>
    </div>
  </HeroParallax>

  <section id="servicios" class="section section-services">
    <div class="container">
      <h2 class="section-title fade-in">Nuestros Servicios</h2>
      <p class="section-subtitle fade-in">Soluciones tecnológicas integrales para empresas modernas</p>
      <div class="services-grid">
        {services.map((s) => (
          <article class="service-card fade-in">
            <div class="service-icon" aria-hidden="true">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <ul>
              {s.features.map((f) => <li>{f}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-about">
    <div class="container">
      <div class="about-grid">
        <div class="fade-in">
          <h2 class="section-title">Sobre PROOQ España</h2>
          <p>
            Somos una empresa tecnológica con sede en Cádiz, especializada en desarrollo web
            y la implementación de agentes inteligentes de interacción con clientes.
          </p>
          <p>
            Nuestro enfoque está en ofrecer soluciones tecnológicas innovadoras para empresas
            locales y regionales en España, combinando la calidez andaluza con la excelencia técnica.
          </p>
          <div class="stats">
            {stats.map((s) => (
              <div class="stat">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="about-image fade-in">
          <img src="/images/esp.jpg" alt="Cádiz, España" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="equipo" class="section section-team">
    <div class="container">
      <h2 class="section-title fade-in">Nuestro Equipo</h2>
      <p class="section-subtitle fade-in">Profesionales apasionados por la tecnología</p>
      {team.map((m) => (
        <article class="team-card fade-in">
          <img src={m.photo} alt={m.name} class="team-photo" loading="lazy" />
          <div class="team-info">
            <h3>{m.name}</h3>
            <h4>{m.role}</h4>
            <p>{m.bio}</p>
            <ul class="skills">
              {m.skills.map((skill) => <li>{skill}</li>)}
            </ul>
            <p class="expertise">{m.expertise}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="portafolio" class="section section-portfolio">
    <div class="container">
      <h2 class="section-title fade-in">Portafolio Web</h2>
      <p class="section-subtitle fade-in">
        Una selección de sitios web diseñados y desarrollados por nuestro equipo en PROOQ España.
        Cada proyecto refleja nuestro compromiso con la innovación, la calidad y la excelencia técnica.
      </p>
      <div class="portfolio-grid">
        {portfolio.map((p) => (
          <article class="portfolio-card fade-in">
            <h3>{p.name}</h3>
            <p>{p.description}</p>
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="portfolio-link">
              Visitar sitio →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="ubicacion" class="section section-location">
    <div class="container">
      <div class="location-grid">
        <div class="fade-in">
          <h2 class="section-title">Ubicados en Cádiz</h2>
          <p>
            Desde el corazón de Andalucía, servimos a empresas de toda España con
            soluciones tecnológicas de vanguardia.
          </p>
          <div class="location-details">
            {locationDetails.map((d) => (
              <div class="location-detail">
                <span class="detail-icon" aria-hidden="true">{d.icon}</span>
                <div>
                  <h4>{d.title}</h4>
                  <p>{d.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="location-image fade-in">
          <img src="/images/esp.jpg" alt="Cádiz, España" loading="lazy" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-extras {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-secondary {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border: 2px solid var(--color-brand-light);
    color: var(--color-brand-light);
    border-radius: var(--radius-pill);
    font-weight: 600;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .cta-secondary:hover,
  .cta-secondary:focus-visible {
    background: var(--color-brand-light);
    color: var(--color-surface);
  }

  .hero-location {
    color: var(--color-text-soft);
    font-size: 0.95rem;
    opacity: 0.85;
    margin: 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section {
    padding: 5rem 0;
  }

  .section + .section {
    border-top: 1px solid rgb(255 255 255 / 0.05);
  }

  .section-services { background: var(--color-surface); }
  .section-about    { background: var(--color-surface-raised); }
  .section-team     { background: var(--color-surface); }
  .section-portfolio{ background: var(--color-surface-raised); }
  .section-location { background: var(--color-surface); }

  .section-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    color: var(--color-text);
    margin: 0 0 0.75rem;
    letter-spacing: 0.05em;
  }

  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin: 0 0 2.5rem;
    max-width: 720px;
  }

  /* fade-in (driven by IntersectionObserver) */
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .fade-in.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Services */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-lg);
    padding: 2rem 1.5rem;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: rgb(0 198 231 / 0.4);
    box-shadow: 0 16px 40px rgb(0 0 0 / 0.4);
  }

  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.4rem;
    margin: 0 0 0.75rem;
  }

  .service-card > p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .service-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .service-card li {
    color: var(--color-text-soft);
    padding: 0.375rem 0 0.375rem 1.25rem;
    position: relative;
  }

  .service-card li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent-cyan);
  }

  /* About + Location grid (2 columns desktop, stacked mobile) */
  .about-grid,
  .location-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .about-grid p,
  .location-grid p {
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .about-image img,
  .location-image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  /* Stats */
  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .stat {
    text-align: center;
    padding: 1.25rem 0.5rem;
    background: var(--color-surface);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-md);
  }

  .stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 700;
    background: linear-gradient(45deg, #ffffff, var(--color-brand-light));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .stat-label {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Team */
  .team-card {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-lg);
    padding: 2rem;
    align-items: start;
  }

  .team-photo {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .team-info h3 {
    font-family: var(--font-display);
    color: var(--color-text);
    font-size: 1.6rem;
    margin: 0;
  }

  .team-info h4 {
    color: var(--color-brand-light);
    font-size: 1rem;
    font-weight: 500;
    margin: 0.25rem 0 1rem;
  }

  .team-info p {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .skills {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skills li {
    background: rgb(0 60 255 / 0.15);
    color: var(--color-brand-light);
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .expertise {
    font-size: 0.9rem;
    color: var(--color-text-muted) !important;
    font-style: italic;
  }

  /* Portfolio */
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .portfolio-card {
    background: var(--color-surface);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .portfolio-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-brand-light);
  }

  .portfolio-card h3 {
    font-family: var(--font-body);
    color: var(--color-text);
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
    word-break: break-all;
  }

  .portfolio-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0 0 1rem;
  }

  .portfolio-link {
    color: var(--color-accent-cyan);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .portfolio-link:hover,
  .portfolio-link:focus-visible {
    text-decoration: underline;
  }

  /* Location */
  .location-details {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .location-detail {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .detail-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .location-detail h4 {
    color: var(--color-text);
    margin: 0 0 0.125rem;
    font-size: 1rem;
  }

  .location-detail p {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .about-grid,
    .location-grid {
      grid-template-columns: 1fr;
    }

    .team-card {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }

    .team-photo {
      max-width: 220px;
    }
  }

  @media (max-width: 600px) {
    .section { padding: 3rem 0; }
    .section-title { font-size: 1.75rem; }
    .stats { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
  // Fade-in al scroll — IntersectionObserver replicado del V1.
  const elements = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' },
  );

  for (const el of elements) observer.observe(el);
</script>
