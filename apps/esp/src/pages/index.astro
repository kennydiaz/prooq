---
import { getTeam } from '@prooq/data-client/team';
import { HeroParallax, Nebula } from '@prooq/ui';
import BaseLayout from '../layouts/BaseLayout.astro';

const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const services = [
  {
    icon: '💻',
    title: 'Desarrollo Web',
    description:
      'Sitios web modernos, responsivos y optimizados. Desde landing pages hasta aplicaciones web complejas con las últimas tecnologías.',
    features: [
      'Diseño responsive y moderno',
      'Optimización SEO',
      'E-commerce y tiendas online',
      'Aplicaciones web personalizadas',
    ],
  },
  {
    icon: '🤖',
    title: 'Agentes Inteligentes',
    description:
      'Chatbots e IA conversacional para automatizar la atención al cliente y mejorar la experiencia de usuario las 24/7.',
    features: [
      'Chatbots inteligentes',
      'Asistentes virtuales',
      'Automatización de procesos',
      'Integración con sistemas existentes',
    ],
  },
  {
    icon: '📱',
    title: 'Consultoría Digital',
    description:
      'Asesoramiento especializado en transformación digital para empresas locales en Cádiz y toda Andalucía.',
    features: [
      'Estrategia digital',
      'Análisis de procesos',
      'Implementación tecnológica',
      'Formación y soporte',
    ],
  },
];

const stats = [
  { value: '50+', label: 'Proyectos Completados' },
  { value: '100%', label: 'Clientes Satisfechos' },
  { value: '15+', label: 'Soporte Técnico' },
];

// Equipo desde el CMS (build-time) con fallback hardcodeado si la API falla.
// skills/expertise no existen en el CMS: solo se muestran en el fallback.
interface EspMember {
  name: string;
  role: string;
  photo: string;
  bio: string;
  skills: string[];
  expertise: string;
}
const fallbackTeam: EspMember[] = [
  {
    name: 'Victor Tineo',
    role: 'Lead Developer & Co-Fundador',
    photo: `${BASE}images/victor.jpg`,
    bio: 'Victor lidera nuestro equipo de desarrollo, especializado en crear experiencias digitales excepcionales y en la implementación de soluciones de IA conversacional.',
    skills: ['React', 'Node.js', 'Python', 'AI/ML', 'ChatGPT API'],
    expertise:
      'Su experiencia en tecnologías modernas y su enfoque en la innovación garantizan que cada proyecto incorpore las mejores prácticas del desarrollo web actual.',
  },
];
const initials = (name: string): string =>
  name
    .split(/\s+/)
    .map((p) => p[0] ?? '')
    .slice(0, 2)
    .join('')
    .toUpperCase();
let team: EspMember[] = fallbackTeam;
try {
  const fetched = await getTeam('ES');
  if (fetched.length > 0) {
    team = fetched.map((m) => ({
      name: m.name,
      role: m.role ?? '',
      photo: m.photoUrl ?? '',
      bio: m.bio ?? '',
      skills: [],
      expertise: '',
    }));
  }
} catch (err) {
  console.warn('[team] getTeam failed, usando fallback:', err);
}

const portfolio = [
  {
    name: 'aerovisionstudio.com',
    description: 'Servicios de drones, fotografía aérea y producción audiovisual.',
    url: 'https://aerovisionstudio.com',
  },
  {
    name: 'prooq.com',
    description: 'Soluciones tecnológicas, seguridad electrónica, infraestructura y sistemas.',
    url: 'https://prooq.com',
  },
  {
    name: 'bgselectrician.com',
    description: 'Manpower & Staffing para contratistas eléctricos.',
    url: 'https://bgselectrician.com',
  },
  {
    name: 'mansionperruna.com',
    description: 'Hotel canino, guardería y servicios premium para mascotas.',
    url: 'https://mansionperruna.com',
  },
  {
    name: 'vieniqua.com',
    description: 'Restaurante de comida italiana.',
    url: 'https://vieniqua.com',
  },
  {
    name: 'cleanfactorypty.com',
    description: 'Servicios profesionales de limpieza de zapatillas.',
    url: 'https://cleanfactorypty.com',
  },
  {
    name: 'varasgrillandbar.com',
    description: 'Restaurante, bar y parrilla con menú y reservas digitales.',
    url: 'https://varasgrillandbar.com',
  },
  {
    name: 'makanolake.com',
    description: 'Cabañas agroturísticas junto al Lago San Carlos.',
    url: 'https://makanolake.com',
  },
  {
    name: 'tallerqsexpress.com',
    description: 'Taller automotriz, mecánica rápida y diagnósticos.',
    url: 'https://tallerqsexpress.com',
  },
  {
    name: 'bootsgloves.com',
    description:
      'Servicios profesionales de demolición, retiro de escombros y limpieza en Atlanta, Georgia.',
    url: 'https://bootsgloves.com',
  },
  {
    name: 'dastvnetwork.com',
    description: 'Tecnología de marketing y publicidad digital.',
    url: 'https://dastvnetwork.com',
  },
  {
    name: 'bgs50.com',
    description: 'Plataforma de servicios y soluciones para la industria.',
    url: 'https://bgs50.com',
  },
] as const;

const locationDetails = [
  { icon: '📍', title: 'Sede Principal', text: 'Cádiz, Andalucía' },
  { icon: '🌍', title: 'Cobertura', text: 'España y Europa' },
  { icon: '⏰', title: 'Horario', text: 'Lun - Vie: 9:00 - 18:00' },
];
---

<BaseLayout
  title="PROOQ España — Desarrollo Web y Agentes Inteligentes | Cádiz"
  description="Especialistas en desarrollo web y agentes inteligentes para empresas en Cádiz y Andalucía. Soluciones tecnológicas innovadoras."
>
  <Nebula />

  <HeroParallax
    title="PROOQ España"
    subtitle="Desarrollo Web & Agentes Inteligentes"
    description="Transformamos tu negocio con soluciones tecnológicas avanzadas desde Cádiz para toda España"
    cta={{ label: 'Nuestros Servicios', href: '#servicios' }}
  >
    <div class="hero-extras">
      <a href="#contact" class="cta-secondary">Contáctanos</a>
      <p class="hero-location">📍 Cádiz, Andalucía — España 🇪🇸</p>
    </div>
  </HeroParallax>

  <section id="servicios" class="section section-services">
    <div class="section-container">
      <h2 class="section-title fade-in">Nuestros Servicios</h2>
      <p class="section-subtitle fade-in">Soluciones tecnológicas integrales para empresas modernas</p>
      <div class="services-grid">
        {services.map((s) => (
          <article class="service-card fade-in">
            <div class="service-icon" aria-hidden="true">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <ul>
              {s.features.map((f) => <li>{f}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-about">
    <div class="section-container">
      <div class="about-grid">
        <div class="fade-in">
          <h2 class="section-title">Sobre PROOQ España</h2>
          <p>
            Somos una empresa tecnológica con sede en Cádiz, especializada en desarrollo web
            y la implementación de agentes inteligentes de interacción con clientes.
          </p>
          <p>
            Nuestro enfoque está en ofrecer soluciones tecnológicas innovadoras para empresas
            locales y regionales en España, combinando la calidez andaluza con la excelencia técnica.
          </p>
          <div class="stats">
            {stats.map((s) => (
              <div class="stat">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="about-image fade-in">
          <img src={`${BASE}images/esp.jpg`} alt="Cádiz, España" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="equipo" class="section section-team">
    <div class="section-container">
      <h2 class="section-title fade-in">Nuestro Equipo</h2>
      <p class="section-subtitle fade-in">Profesionales apasionados por la tecnología</p>
      {team.map((m) => (
        <article class="team-card fade-in">
          {m.photo ? (
            <img src={m.photo} alt={m.name} class="team-photo" loading="lazy" />
          ) : (
            <span class="team-photo team-avatar-fallback" aria-hidden="true">{initials(m.name)}</span>
          )}
          <div class="team-info">
            <h3>{m.name}</h3>
            <h4>{m.role}</h4>
            {m.bio && <p>{m.bio}</p>}
            {m.skills.length > 0 && (
              <ul class="skills">
                {m.skills.map((skill) => <li>{skill}</li>)}
              </ul>
            )}
            {m.expertise && <p class="expertise">{m.expertise}</p>}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="portafolio" class="section section-portfolio">
    <div class="section-container">
      <h2 class="section-title fade-in">Portafolio Web</h2>
      <p class="section-subtitle fade-in">
        Una selección de sitios web diseñados y desarrollados por nuestro equipo en PROOQ España.
        Cada proyecto refleja nuestro compromiso con la innovación, la calidad y la excelencia técnica.
      </p>
      <div class="portfolio-grid">
        {portfolio.map((p) => (
          <article class="portfolio-card fade-in">
            <h3>{p.name}</h3>
            <p>{p.description}</p>
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="portfolio-link">
              Visitar sitio →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="ubicacion" class="section section-location">
    <div class="section-container">
      <div class="location-grid">
        <div class="fade-in">
          <h2 class="section-title">Ubicados en Cádiz</h2>
          <p>
            Desde el corazón de Andalucía, servimos a empresas de toda España con
            soluciones tecnológicas de vanguardia.
          </p>
          <div class="location-details">
            {locationDetails.map((d) => (
              <div class="location-detail">
                <span class="detail-icon" aria-hidden="true">{d.icon}</span>
                <div>
                  <h4>{d.title}</h4>
                  <p>{d.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="location-image fade-in">
          <img src={`${BASE}images/esp.jpg`} alt="Cádiz, España" loading="lazy" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>


<script>
  // Fade-in al scroll — IntersectionObserver replicado del V1.
  const elements = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' },
  );

  for (const el of elements) observer.observe(el);
</script>
