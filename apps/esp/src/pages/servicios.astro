---
import { NeonPriceSticker } from '@prooq/ui';
import BaseLayout from '../layouts/BaseLayout.astro';

interface DigitalService {
  icon: string;
  title: string;
  description: string;
  features: readonly string[];
  highlight?: boolean;
}

const services: readonly DigitalService[] = [
  {
    icon: '💻',
    title: 'Desarrollo Web',
    description:
      'Sitios web modernos, responsivos y optimizados. Desde landing pages hasta aplicaciones web complejas.',
    features: [
      'Diseño responsive y moderno',
      'Optimización SEO',
      'E-commerce y tiendas online',
      'Aplicaciones web personalizadas',
      'CMS administrables',
    ],
    highlight: true,
  },
  {
    icon: '🤖',
    title: 'Agentes Inteligentes',
    description: 'Chatbots e IA conversacional para automatizar la atención al cliente 24/7.',
    features: [
      'Chatbots inteligentes con n8n',
      'Asistentes virtuales',
      'Automatización de procesos',
      'Integración con sistemas existentes',
      'Workflows IA personalizados',
    ],
    highlight: true,
  },
  {
    icon: '📱',
    title: 'Consultoría Digital',
    description:
      'Asesoramiento especializado en transformación digital para empresas en Cádiz y Andalucía.',
    features: [
      'Estrategia digital',
      'Análisis de procesos',
      'Implementación tecnológica',
      'Formación y soporte',
    ],
  },
];
---

<BaseLayout
  title="Servicios Digitales — PROOQ España"
  description="Servicios digitales de PROOQ España: desarrollo web, agentes inteligentes con n8n, consultoría digital en Cádiz y Andalucía."
>
  <section class="section section-services servicios-page">
    <div class="section-container">
      <h1 class="section-title fade-in">Servicios Digitales</h1>
      <p class="section-subtitle fade-in">
        Soluciones técnicas integrales para empresas en España: desarrollo web, IA conversacional y consultoría digital.
        Cotización personalizada por proyecto — sin compromiso.
      </p>

      <div class="services-grid">
        {services.map((s) => (
          <article class={`service-card fade-in${s.highlight ? ' service-card-featured' : ''}`}>
            <div class="service-icon" aria-hidden="true">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <ul>{s.features.map((f) => <li>{f}</li>)}</ul>
            <div class="service-cta">
              <NeonPriceSticker label="Cotización" price="Gratis" />
            </div>
          </article>
        ))}
      </div>

      <aside class="services-note fade-in">
        <h2>¿No encuentras lo que buscas?</h2>
        <p>Hacemos proyectos a medida. Si necesitas algo fuera del catálogo, contáctanos y armamos la solución contigo.</p>
        <a href="#contact" class="cta-secondary">Conversemos</a>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .servicios-page { padding-top: 8rem; }
  .service-card { display: flex; flex-direction: column; }
  .service-card-featured {
    border-color: rgb(0 255 231 / 0.3);
    background: linear-gradient(180deg, var(--color-surface-raised) 0%, rgb(0 60 255 / 0.08) 100%);
  }
  .service-card-featured:hover {
    border-color: var(--color-accent-cyan);
    box-shadow: 0 16px 40px rgb(0 255 231 / 0.18);
  }
  .service-cta { margin-top: auto; padding-top: 1.25rem; display: flex; justify-content: flex-start; }
  .services-note { margin-top: 4rem; padding: 2rem; text-align: center; background: var(--color-surface-raised); border: 1px solid rgb(255 255 255 / 0.06); border-radius: var(--radius-lg); }
  .services-note h2 { font-family: var(--font-display); color: var(--color-text); font-size: 1.5rem; margin: 0 0 0.5rem; }
  .services-note p { color: var(--color-text-muted); margin: 0 0 1.5rem; line-height: 1.6; }
</style>

<script>
  const els = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => { for (const e of entries) if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); } },
    { threshold: 0.05, rootMargin: '0px 0px -50px 0px' },
  );
  for (const el of els) observer.observe(el);
</script>
