---

<BaseLayout
  title="PROOQ LLC — Technology Solutions in Chicago, IL"
  description="Specialists in structured cabling, electronic security, and business automation. Based in Elmwood Park, IL serving the United States."
>
  <HeroParallax
    title="PROOQ"
    subtitle="Comprehensive technology solutions for businesses"
    description="Specialists in structured cabling, electronic security, and business automation in the United States"
    cta={{ label: 'Discover our services', href: '#servicios' }}
  >
    <div class="hero-extras">
      <a href="#contact" class="cta-secondary">Contact us</a>
      <p class="hero-location">📍 Elmwood Park, IL — United States 🇺🇸</p>
    </div>
  </HeroParallax>

  <section id="servicios" class="section section-services">
    <div class="section-container">
      <h2 class="section-title fade-in">Special Services</h2>
      <p class="section-subtitle fade-in">Comprehensive technology solutions for modern businesses</p>
      <div class="services-grid">
        {services.map((s) => (
          <article class="service-card fade-in">
            <div class="service-icon" aria-hidden="true">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.description}</p>
            <ul>
              {s.features.map((f) => <li>{f}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-about">
    <div class="section-container">
      <div class="about-grid">
        <div class="fade-in">
          <h2 class="section-title">About PROOQ LLC</h2>
          <p>
            Empowering US businesses with reliable, scalable technology infrastructure. From
            our office in Elmwood Park, IL we serve clients across the United States in
            structured cabling, electronic security and business automation.
          </p>
          <p>
            We combine technical expertise with personalized service, helping organizations
            modernize their operations and stay secure in an increasingly connected world.
          </p>
          <div class="stats">
            {stats.map((s) => (
              <div class="stat">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="equipo" class="section section-team">
    <div class="section-container">
      <h2 class="section-title fade-in">Our Team</h2>
      <p class="section-subtitle fade-in">The professionals behind every PROOQ project</p>
      <div class="team-grid">
        {team.map((m) => (
          <article class="team-member fade-in">
            <img src={m.photo} alt={m.name} loading="lazy" />
            <h3>{m.name}</h3>
            <p>{m.role}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="portafolio" class="section section-portfolio">
    <div class="section-container">
      <h2 class="section-title fade-in">Web Portfolio</h2>
      <p class="section-subtitle fade-in">
        A selection of websites designed and developed by our team. Each project reflects our
        commitment to innovation, quality and technical excellence.
      </p>
      <div class="portfolio-grid">
        {portfolio.map((p) => (
          <article class="portfolio-card fade-in">
            <h3>{p.name}</h3>
            <p>{p.description}</p>
            <a href={p.url} target="_blank" rel="noopener noreferrer" class="portfolio-link">
              Visit site →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="ubicacion" class="section section-location">
    <div class="section-container">
      <div class="location-grid">
        <div class="fade-in">
          <h2 class="section-title">Based in Elmwood Park, IL</h2>
          <p>
            From the Chicago metro area, we serve businesses across the United States with
            cutting-edge technology solutions.
          </p>
          <div class="location-details">
            {locationDetails.map((d) => (
              <div class="location-detail">
                <span class="detail-icon" aria-hidden="true">{d.icon}</span>
                <div>
                  <h4>{d.title}</h4>
                  <p>{d.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Fade-in al scroll — IntersectionObserver replicado del V1.
  const elements = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' },
  );

  for (const el of elements) observer.observe(el);
</script>
