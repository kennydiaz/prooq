---
import { type GalleryItem, getGallery } from '@prooq/data-client/gallery';
import BaseLayout from '../layouts/BaseLayout.astro';

let items: readonly GalleryItem[] = [];
try {
  items = await getGallery({ country: 'US' });
} catch (err) {
  console.warn('[gallery] getGallery failed:', err);
}
---

<BaseLayout
  title="Gallery — PROOQ USA"
  description="Gallery of PROOQ projects, installations and field operations in the United States."
>
  <section class="section section-services gallery-page">
    <div class="section-container">
      <h1 class="section-title fade-in">Gallery</h1>
      <p class="section-subtitle fade-in">
        A look at our projects, installations and the PROOQ team on the field.
      </p>

      {items.length === 0 ? (
        <p class="gallery-empty fade-in">No images published yet.</p>
      ) : (
        <div class="gallery-grid">
          {items.map((it) => (
            <figure class="gallery-card fade-in">
              <img
                src={it.url}
                alt={it.alt ?? it.title ?? 'PROOQ gallery image'}
                loading="lazy"
                width={it.widthPx ?? undefined}
                height={it.heightPx ?? undefined}
              />
              {(it.title || it.caption) && (
                <figcaption>
                  {it.title && <strong>{it.title}</strong>}
                  {it.caption && <span>{it.caption}</span>}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-page {
    padding-top: 8rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .gallery-card {
    margin: 0;
    background: var(--color-surface-raised);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .gallery-card:hover {
    transform: translateY(-4px);
    border-color: rgb(0 198 231 / 0.4);
    box-shadow: 0 12px 32px rgb(0 0 0 / 0.35);
  }

  .gallery-card img {
    display: block;
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  .gallery-card figcaption {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .gallery-card figcaption strong {
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .gallery-card figcaption span {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .gallery-empty {
    margin-top: 2rem;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>

<script>
  const fadeEls = document.querySelectorAll('.fade-in');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          observer.unobserve(e.target);
        }
      }
    },
    { threshold: 0.05, rootMargin: '0px 0px -40px 0px' },
  );
  for (const el of fadeEls) observer.observe(el);
</script>
