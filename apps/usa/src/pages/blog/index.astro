---
import { getCollection } from 'astro:content';
import { BlogList } from '@prooq/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    description: p.data.description,
    pubDate: p.data.pubDate,
    tags: p.data.tags,
  }));
---

<BaseLayout
  title="Blog | PROOQ LLC — Technology and automation for small businesses"
  description="Practical articles on AI automation, electronic security, web development and technology for businesses in the U.S."
>
  <BlogList posts={posts} locale="en-US" />
</BaseLayout>
