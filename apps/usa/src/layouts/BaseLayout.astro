---
import '@prooq/styles/globals.css';
import '@prooq/styles/sections.css';
import { CountriesMenu, Footer, Header, Seo, VisitTracker } from '@prooq/ui';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
}

const { title, description, image, type, publishedDate } = Astro.props;
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo
      site="usa"
      {title}
      description={description ?? title}
      {image}
      {type}
      {publishedDate}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Orbitron:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header country="usa" logoSrc={`${BASE}images/logoblanco.png`} logoAlt="PROOQ LLC">
      <CountriesMenu slot="countries-menu" current="usa" label="🌐 Countries" />
    </Header>
    <main>
      <slot />
    </main>
    <Footer
      country="usa"
      contact={{
        email: 'info@prooq.com',
        phone: '+1 (708) 540-0888',
        whatsapp: '+1 (708) 540-0888',
        address: '2512 N 72nd Ct, Elmwood Park, IL — USA',
      }}
      copyrightName="PROOQ LLC"
      socialTitle="Follow Us on Social Media"
      socialSubtitle="Stay connected and discover the latest updates"
    />
    <VisitTracker site="usa" />
  </body>
</html>
